@model proekt.Models.ViewModels.MedicalRecordViewModel
@inject proekt.Services.TranslationService Loc
@{
    ViewData["Title"] = "Medical Record – " + Model.Patient.FullName;
    var canEdit = Model.CanEdit;
    var canEditBasicInfo = Model.CanEditBasicInfo;
    var record = Model.Record;
    var userId = Model.Patient.Id;

    var operations  = record.Entries.Where(e => e.Type == proekt.Models.MedicalEntryType.Operation  && !e.IsDeleted).OrderByDescending(e => e.Date).ToList();
    var diagnoses   = record.Entries.Where(e => e.Type == proekt.Models.MedicalEntryType.Diagnosis  && !e.IsDeleted).OrderByDescending(e => e.Date).ToList();
    var medications = record.Entries.Where(e => e.Type == proekt.Models.MedicalEntryType.Medication && !e.IsDeleted).OrderByDescending(e => e.Date).ToList();
    var notes       = record.Entries.Where(e => e.Type == proekt.Models.MedicalEntryType.Note       && !e.IsDeleted).OrderByDescending(e => e.Date).ToList();
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

<div class="mr-page">
    <!-- ── Header ─────────────────────────────────────── -->
    <div class="mr-header" style="background: var(--grad-dark); border-radius: 24px; padding: 3rem; margin: 1rem; box-shadow: var(--shadow-xl);">
        <div class="mr-header-left d-flex align-items-center">
            <div class="mr-avatar shadow-lg" style="width: 80px; height: 80px; font-size: 2.5rem; background: var(--grad-primary); border: 4px solid rgba(255,255,255,0.2); border-radius: 20px; display: flex; align-items: center; justify-content: center; font-weight: 900; color: white;">
                @(Model.Patient.FullName?.Substring(0,1).ToUpper() ?? "?")
            </div>
            <div class="ms-4">
                <h2 class="mb-1 fw-900 text-white" style="letter-spacing: -1px;">@Model.Patient.FullName</h2>
                <div class="d-flex align-items-center gap-3">
                    <small class="text-white-50"><i class="bi bi-envelope me-1"></i> @Model.Patient.Email</small>
                    <small class="text-white-50"><i class="bi bi-calendar-event me-1"></i> Member since @Model.Patient.CreatedAt.ToString("MMM yyyy")</small>
                </div>
                <div class="mt-2"><span class="badge rounded-pill px-3 py-2" style="background: rgba(255,255,255,0.1); backdrop-filter: blur(4px); border: 1px solid rgba(255,255,255,0.2);">@Model.Patient.Role</span></div>
            </div>
        </div>
        <div class="mr-header-right">
            @if (canEditBasicInfo)
            {
                <button class="btn btn-light btn-sm" onclick="openEditInfoModal()">
                    <i class="bi bi-pencil-square"></i> @Loc.T("EditGeneralInfo")
                </button>
            }
            <a href="@(Context.Session.GetString("UserRole") is "Doctor" or "Admin" or "Manager" ? Url.Action("DoctorDashboard","MedicalRecord") : Url.Action("Profile","Home"))"
               class="btn btn-outline-light btn-sm">
                <i class="bi bi-arrow-left"></i> @Loc.T("Back")
            </a>
        </div>
    </div>

    @if (TempData["RecordMessage"] != null)
    {
        <div class="alert alert-success mx-3 mt-3 mb-0">@TempData["RecordMessage"]</div>
    }

    <!-- ── General Info Cards ─────────────────────────── -->
    <div class="row g-4 px-3 mb-5 fade-in-up">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 overflow-hidden glass-card hover-scale">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="flex-shrink-0 p-3 rounded-4 me-3 shadow-sm" style="background: var(--grad-danger); color: white;">
                        <i class="bi bi-droplet-fill fs-3"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold text-uppercase" style="letter-spacing: 1px;">@Loc.T("BloodType")</div>
                        <div class="h4 mb-0 fw-900">@(string.IsNullOrWhiteSpace(record.BloodType) ? "—" : record.BloodType)</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 overflow-hidden glass-card hover-scale">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="flex-shrink-0 p-3 rounded-4 me-3 shadow-sm" style="background: var(--grad-premium); color: white;">
                        <i class="bi bi-exclamation-triangle-fill fs-3"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold text-uppercase" style="letter-spacing: 1px;">@Loc.T("Allergies")</div>
                        <div class="h6 mb-0 fw-bold">@(string.IsNullOrWhiteSpace(record.Allergies) ? "None" : record.Allergies)</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 overflow-hidden glass-card hover-scale">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="flex-shrink-0 p-3 rounded-4 me-3 shadow-sm" style="background: var(--grad-primary); color: white;">
                        <i class="bi bi-heart-pulse-fill fs-3"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold text-uppercase" style="letter-spacing: 1px;">@Loc.T("Chronic")</div>
                        <div class="h6 mb-0 fw-bold">@(string.IsNullOrWhiteSpace(record.ChronicConditions) ? "None" : record.ChronicConditions)</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 overflow-hidden glass-card hover-scale">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="flex-shrink-0 p-3 rounded-4 me-3 shadow-sm" style="background: var(--grad-success); color: white;">
                        <i class="bi bi-journal-text fs-3"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold text-uppercase" style="letter-spacing: 1px;">@Loc.T("TotalEntries")</div>
                        <div class="h4 mb-0 fw-900">@record.Entries.Count</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Category Navigation Buttons ────────────────────────────── -->
    <div class="px-3 mb-5">
        <div class="glass-card p-3 rounded-4 shadow-sm d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-premium-nav active" id="btn-tab-operations" onclick="toggleMrSection('operations')">
                    <i class="bi bi-scissors me-2"></i> @Loc.T("Operations")
                </button>
                <button class="btn btn-premium-nav" id="btn-tab-diagnoses" onclick="toggleMrSection('diagnoses')">
                    <i class="bi bi-activity me-2"></i> @Loc.T("Diagnoses")
                </button>
                <button class="btn btn-premium-nav" id="btn-tab-medications" onclick="toggleMrSection('medications')">
                    <i class="bi bi-capsule me-2"></i> @Loc.T("Medications")
                </button>
                <button class="btn btn-premium-nav" id="btn-tab-notes" onclick="toggleMrSection('notes')">
                    <i class="bi bi-sticky me-2"></i> @Loc.T("Notes")
                </button>
                <button class="btn btn-premium-nav" id="btn-tab-history" onclick="toggleMrSection('history')">
                    <i class="bi bi-clock-history me-2"></i> @Loc.T("History")
                </button>
            </div>
            
            <div id="add-btn-container">
                @if (canEdit) {
                    <button class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold hover-scale" id="main-add-btn" onclick="openAddModal()">
                        <i class="bi bi-plus-lg me-2"></i> @Loc.T("AddEntry")
                    </button>
                }
            </div>
        </div>
    </div>

    <!-- ── Content Sections ───────────────────────────────────────── -->
    <div class="px-3">
        <!-- Operations Section -->
        <div class="mr-category-section active" id="sec-operations">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-900 mb-0"><i class="bi bi-scissors me-2 text-danger"></i> @Loc.T("Operations")</h4>
                <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3">@operations.Count Entries</span>
            </div>
            @if (!operations.Any()) {
                <div class="mr-empty"><i class="bi bi-scissors"></i><p>@Loc.T("NoOperations")</p></div>
            }
            @foreach (var e in operations) {
                @await Html.PartialAsync("_EntryCard", new ViewDataDictionary(ViewData) { { "Entry", e }, { "UserId", userId }, { "CanEdit", canEdit } })
            }
        </div>

        <!-- Diagnoses Section -->
        <div class="mr-category-section d-none" id="sec-diagnoses">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-900 mb-0"><i class="bi bi-activity me-2 text-primary"></i> @Loc.T("Diagnoses")</h4>
                <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3">@diagnoses.Count Entries</span>
            </div>
            @if (!diagnoses.Any()) {
                <div class="mr-empty"><i class="bi bi-activity"></i><p>@Loc.T("NoDiagnoses")</p></div>
            }
            @foreach (var e in diagnoses) {
                @await Html.PartialAsync("_EntryCard", new ViewDataDictionary(ViewData) { { "Entry", e }, { "UserId", userId }, { "CanEdit", canEdit } })
            }
        </div>

        <!-- Medications Section -->
        <div class="mr-category-section d-none" id="sec-medications">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-900 mb-0"><i class="bi bi-capsule me-2 text-info"></i> @Loc.T("Medications")</h4>
                <span class="badge bg-info bg-opacity-10 text-info rounded-pill px-3">@medications.Count Entries</span>
            </div>
            @if (!medications.Any()) {
                <div class="mr-empty"><i class="bi bi-capsule"></i><p>@Loc.T("NoMedications")</p></div>
            }
            @foreach (var e in medications) {
                @await Html.PartialAsync("_EntryCard", new ViewDataDictionary(ViewData) { { "Entry", e }, { "UserId", userId }, { "CanEdit", canEdit } })
            }
        </div>

        <!-- Notes Section -->
        <div class="mr-category-section d-none" id="sec-notes">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-900 mb-0"><i class="bi bi-sticky me-2 text-success"></i> @Loc.T("Notes")</h4>
                <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">@notes.Count Entries</span>
            </div>
            @if (!notes.Any()) {
                <div class="mr-empty"><i class="bi bi-sticky"></i><p>@Loc.T("NoNotes")</p></div>
            }
            @foreach (var e in notes) {
                @await Html.PartialAsync("_EntryCard", new ViewDataDictionary(ViewData) { { "Entry", e }, { "UserId", userId }, { "CanEdit", canEdit } })
            }
        </div>

        <!-- History Section -->
        <div class="mr-category-section d-none" id="sec-history">
            <h4 class="fw-900 mb-4"><i class="bi bi-clock-history me-2 text-secondary"></i> @Loc.T("History")</h4>
            <div class="mr-timeline">
                @foreach (var log in Model.AuditLogs) {
                    var hasDiff = !string.IsNullOrEmpty(log.OldSnapshot) && !string.IsNullOrEmpty(log.NewSnapshot);
                    <div class="mr-timeline-item">
                        <div class="mr-timeline-dot"></div>
                        <div class="mr-timeline-body">
                            <div class="mr-timeline-header">
                                <strong>@log.ActionType</strong>
                                <span class="mr-timeline-meta"><i class="bi bi-person-badge"></i> @log.DoctorName &nbsp;&nbsp; <i class="bi bi-clock"></i> @log.Timestamp.ToString("g")</span>
                            </div>
                            <div class="text-muted small">@log.Details</div>
                            @if (hasDiff) {
                                <button class="btn btn-outline-info btn-xs mt-2" onclick="toggleDiff('diff-@log.Id')">Show Diff</button>
                                <div id="diff-@log.Id" class="audit-diff-panel" style="display:none;">
                                    @{
                                        var oldD = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string,string?>>(log.OldSnapshot!)!;
                                        var newD = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string,string?>>(log.NewSnapshot!)!;
                                        var fieldLabels = new Dictionary<string,string> { ["BloodType"]="Blood Type", ["Allergies"]="Allergies", ["ChronicConditions"]="Chronic Conditions", ["GeneralNotes"]="General Notes" };
                                    }
                                    <table class="diff-table mt-2">
                                        <thead><tr><th>Field</th><th class="diff-old">Before</th><th class="diff-new">After</th></tr></thead>
                                        <tbody>
                                        @foreach (var key in fieldLabels.Keys) {
                                            var oldVal = oldD.ContainsKey(key) ? oldD[key] : null;
                                            var newVal = newD.ContainsKey(key) ? newD[key] : null;
                                            var changed = oldVal != newVal;
                                            <tr class="@(changed ? "diff-row-changed" : "diff-row-same")">
                                                <td class="diff-field">@fieldLabels[key]</td>
                                                <td class="diff-old">@(string.IsNullOrWhiteSpace(oldVal) ? "—" : oldVal)</td>
                                                <td class="diff-new">@(string.IsNullOrWhiteSpace(newVal) ? "—" : newVal)</td>
                                            </tr>
                                        }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
    </div>
</div>

<!-- ══ Add Entry Modal ══════════════════════════════════════════ -->
@if (canEdit)
{
    <div class="mr-modal-overlay" id="addEntryModal" onclick="closeFn(event,'addEntryModal')">
        <div class="mr-modal shadow-2xl border-0 overflow-hidden">
            <div class="mr-modal-header text-white" style="background: var(--grad-primary); border: none; padding: 1.5rem 2rem;">
                <h5 class="mb-0 fw-900" style="letter-spacing: -0.5px;"><i class="bi bi-plus-circle-fill me-2"></i>@Loc.T("AddMedicalEntry")</h5>
                <button type="button" class="text-white opacity-75 hover-opacity-100" onclick="closeModal('addEntryModal')"><i class="bi bi-x-lg"></i></button>
            </div>
            <form asp-controller="MedicalRecord" asp-action="AddEntry" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" value="@userId" />
                <div class="mr-modal-body">
                    <div class="mr-form-row">
                        <div class="mr-form-group">
                            <label>@Loc.T("EntryType")</label>
                            <select name="type" id="add_type" class="mr-select" required>
                                <option value="Operation">@Loc.T("Operations")</option>
                                <option value="Diagnosis">@Loc.T("Diagnoses")</option>
                                <option value="Medication">@Loc.T("Medications")</option>
                                <option value="Note">@Loc.T("Notes")</option>
                            </select>
                        </div>
                        <div class="mr-form-group">
                            <label>@Loc.T("Date")</label>
                            <input type="date" name="date" class="mr-input" value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                        </div>
                    </div>
                    <div class="mr-form-group">
                        <label>@Loc.T("Title")</label>
                        <input type="text" name="title" class="mr-input" placeholder="e.g. Appendectomy" required />
                    </div>
                    <div class="mr-form-group">
                        <label>@Loc.T("Description")</label>
                        <textarea name="description" class="mr-textarea" rows="4" placeholder="Detailed description..."></textarea>
                    </div>
                </div>
                <div class="mr-modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="closeModal('addEntryModal')">@Loc.T("Cancel")</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>@Loc.T("SaveEntry")</button>
                </div>
            </form>
        </div>
    </div>

    <!-- ══ Edit Entry Modal ═══════════════════════════════════════ -->
    <div class="mr-modal-overlay" id="editEntryModal" onclick="closeFn(event,'editEntryModal')">
        <div class="mr-modal shadow-2xl border-0 overflow-hidden">
            <div class="mr-modal-header text-white" style="background: var(--grad-premium); border: none; padding: 1.5rem 2rem;">
                <h5 class="mb-0 fw-900" style="letter-spacing: -0.5px;"><i class="bi bi-pencil-fill me-2"></i>@Loc.T("UpdateEntry")</h5>
                <button type="button" class="text-white opacity-75 hover-opacity-100" onclick="closeModal('editEntryModal')"><i class="bi bi-x-lg"></i></button>
            </div>
            <form asp-controller="MedicalRecord" asp-action="EditEntry" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="entryId" id="edit_entryId" />
                <input type="hidden" name="userId" value="@userId" />
                <div class="mr-modal-body">
                    <div class="mr-form-row">
                        <div class="mr-form-group">
                            <label>@Loc.T("EntryType")</label>
                            <select name="type" id="edit_type" class="mr-select" required>
                                <option value="Operation">@Loc.T("Operations")</option>
                                <option value="Diagnosis">@Loc.T("Diagnoses")</option>
                                <option value="Medication">@Loc.T("Medications")</option>
                                <option value="Note">@Loc.T("Notes")</option>
                            </select>
                        </div>
                        <div class="mr-form-group">
                            <label>@Loc.T("Date")</label>
                            <input type="date" name="date" id="edit_date" class="mr-input" required />
                        </div>
                    </div>
                    <div class="mr-form-group">
                        <label>@Loc.T("Title")</label>
                        <input type="text" name="title" id="edit_title" class="mr-input" required />
                    </div>
                    <div class="mr-form-group">
                        <label>@Loc.T("Description")</label>
                        <textarea name="description" id="edit_description" class="mr-textarea" rows="4"></textarea>
                    </div>
                </div>
                <div class="mr-modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="closeModal('editEntryModal')">@Loc.T("Cancel")</button>
                    <button type="submit" class="btn btn-warning text-white"><i class="bi bi-check-lg me-1"></i>@Loc.T("UpdateEntry")</button>
                </div>
            </form>
        </div>
    </div>
}

    <!-- ══ Edit General Info Modal ═══════════════════════════════ -->
    <div class="mr-modal-overlay" id="editInfoModal" onclick="closeFn(event,'editInfoModal')">
        <div class="mr-modal shadow-2xl border-0 overflow-hidden">
            <div class="mr-modal-header text-white" style="background: var(--grad-success); border: none; padding: 1.5rem 2rem;">
                <h5 class="mb-0 fw-900" style="letter-spacing: -0.5px;"><i class="bi bi-clipboard2-pulse-fill me-2"></i>@Loc.T("EditGeneralInfo")</h5>
                <button type="button" class="text-white opacity-75 hover-opacity-100" onclick="closeModal('editInfoModal')"><i class="bi bi-x-lg"></i></button>
            </div>
            <form asp-controller="MedicalRecord" asp-action="UpdateRecordInfo" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" value="@userId" />
                <div class="mr-modal-body">
                    <div class="mr-form-group">
                        <label>@Loc.T("BloodType")</label>
                        <select name="bloodType" class="mr-select">
                            <option value="">— @Loc.T("Back") —</option>
                            @foreach (var bt in new[]{"A+","A-","B+","B-","AB+","AB-","O+","O-"})
                            {
                                if (record.BloodType == bt)
                                {
                                    <option value="@bt" selected>@bt</option>
                                }
                                else
                                {
                                    <option value="@bt">@bt</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mr-form-group">
                        <label>@Loc.T("Allergies")</label>
                        <textarea name="allergies" class="mr-textarea" rows="2" placeholder="e.g. Penicillin, Pollen...">@record.Allergies</textarea>
                    </div>
                    <div class="mr-form-group">
                        <label>@Loc.T("ChronicConditions")</label>
                        <textarea name="chronicConditions" class="mr-textarea" rows="2" placeholder="e.g. Hypertension, Diabetes...">@record.ChronicConditions</textarea>
                    </div>
                    <div class="mr-form-group">
                        <label>@Loc.T("GeneralNotes")</label>
                        <textarea name="generalNotes" class="mr-textarea" rows="3">@record.GeneralNotes</textarea>
                    </div>
                </div>
                <div class="mr-modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="closeModal('editInfoModal')">@Loc.T("Cancel")</button>
                    <button type="submit" class="btn btn-success"><i class="bi bi-check-lg me-1"></i>@Loc.T("SaveChanges")</button>
                </div>
            </form>
        </div>
    </div>


@section Scripts {
<script>
let currentCategory = 'operations';

function toggleMrSection(category) {
    // Hide current section
    document.getElementById('sec-' + currentCategory).classList.add('d-none');
    document.getElementById('btn-tab-' + currentCategory).classList.remove('active');
    
    // Show new section
    document.getElementById('sec-' + category).classList.remove('d-none');
    document.getElementById('btn-tab-' + category).classList.add('active');
    
    currentCategory = category;

    // Update main add button if needed or handle specific section logic
    const addBtn = document.getElementById('main-add-btn');
    if (addBtn) {
        if (category === 'history') {
            addBtn.style.display = 'none';
        } else {
            addBtn.style.display = 'inline-flex';
            // Pre-set the type for the next open
            let typeMap = {
                'operations': 'Operation',
                'diagnoses': 'Diagnosis',
                'medications': 'Medication',
                'notes': 'Note'
            };
            window.lastSelectedType = typeMap[category];
        }
    }
}

function openAddModal() { 
    const type = window.lastSelectedType || 'Diagnosis';
    document.getElementById('add_type').value = type;
    document.getElementById('addEntryModal').classList.add('show'); 
}
function openEditInfoModal() { document.getElementById('editInfoModal').classList.add('show'); }
function closeModal(id)  { document.getElementById(id).classList.remove('show'); }
function closeFn(e, id) { if (e.target.id === id) closeModal(id); }

function openEditModal(entryId, type, title, description, date) {
    document.getElementById('edit_entryId').value     = entryId;
    document.getElementById('edit_type').value        = type;
    document.getElementById('edit_title').value       = title;
    document.getElementById('edit_description').value = description;
    document.getElementById('edit_date').value        = date;
    document.getElementById('editEntryModal').classList.add('show');
}

function toggleDiff(id) {
    const panel = document.getElementById(id);
    const btn   = panel.previousElementSibling;
    const visible = panel.style.display !== 'none';
    panel.style.display = visible ? 'none' : 'block';
    btn.innerHTML = visible
        ? '<i class="bi bi-eye"></i> Show Diff'
        : '<i class="bi bi-eye-slash"></i> Hide Diff';
}
</script>
}
