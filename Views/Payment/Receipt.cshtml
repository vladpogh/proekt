@model proekt.Models.Payment
@{
    ViewData["Title"] = "Payment Receipt";
    var doctor  = ViewBag.Doctor      as proekt.Models.User;
    var patient = ViewBag.Patient     as proekt.Models.User;
    var appt    = ViewBag.Appointment as proekt.Models.Appointment;
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<div class="py-5" style="background:#f8faff;min-height:calc(100vh - 100px)">
<div class="container" style="max-width:600px">
    <div class="receipt-card p-5">
        <div class="text-center mb-4">
            <svg width="40" height="40" viewBox="0 0 32 32" fill="none" class="mb-2"><rect width="32" height="32" rx="8" fill="#0052CC"/><path d="M16 6L22 14H10L16 6Z" fill="white"/><path d="M10 14L16 26L22 14" fill="white" opacity="0.7"/></svg>
            <h5 class="fw-bold mb-0">MedReports</h5>
            <p class="text-muted small">Official Payment Receipt</p>
        </div>

        <div class="success-banner p-3 rounded-3 text-center mb-4">
            <i class="bi bi-check-circle-fill text-success fs-4 d-block mb-1"></i>
            <strong>Payment Confirmed</strong>
            <p class="mb-0 small text-muted">@Model.PaidAt?.ToString("dddd, dd MMMM yyyy 'at' HH:mm")</p>
        </div>

        <div class="receipt-rows mb-4">
            <div class="receipt-row"><span>Receipt #</span><strong>#@Model.Id</strong></div>
            <div class="receipt-row"><span>Patient</span><strong>@patient?.FullName</strong></div>
            <div class="receipt-row"><span>Doctor</span><strong>Dr. @doctor?.FullName</strong></div>
            @if (appt != null)
            {
                <div class="receipt-row"><span>Appointment</span><strong>@appt.AppointmentDate.ToString("dd MMM yyyy, HH:mm")</strong></div>
            }
            <div class="receipt-row"><span>Currency</span><strong>@Model.Currency</strong></div>
            <div class="receipt-row total-row"><span>Total Paid</span><strong class="text-success fs-5">@Model.Amount.ToString("F2") @Model.Currency</strong></div>
        </div>

        <div class="d-flex gap-2 justify-content-center">
            <button class="btn btn-primary rounded-pill px-4" onclick="window.print()">
                <i class="bi bi-printer me-2"></i>Print Receipt
            </button>
            <a asp-controller="Payment" asp-action="History" class="btn btn-outline-secondary rounded-pill px-4">Back to History</a>
        </div>
    </div>
</div>
</div>
<style>
.receipt-card { background:white;border-radius:24px;box-shadow:0 16px 48px rgba(0,0,0,0.08);border:1px solid #edf2f7; }
.success-banner { background:#f0fdf4;border:1px solid #bbf7d0; }
.receipt-rows { border-top:1px solid #f1f5f9; }
.receipt-row { display:flex;justify-content:space-between;align-items:center;padding:0.75rem 0;border-bottom:1px solid #f1f5f9; }
.total-row { border-top:2px solid #e2e8f0;margin-top:0.5rem;padding-top:1rem;border-bottom:none; }
@@media print {
    header, footer, nav, .btn { display:none !important; }
    .receipt-card { box-shadow:none; }
    body { background:white !important; }
}
</style>
