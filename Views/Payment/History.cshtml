@{
    ViewData["Title"] = "Payment History";
    var items = ViewBag.Items as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<div class="py-5" style="background:#f8faff;min-height:calc(100vh - 100px)">
<div class="container">
    <div class="d-flex align-items-center gap-3 mb-5">
        <div class="icon-badge bg-primary-soft fs-4"><i class="bi bi-receipt text-primary"></i></div>
        <div><h1 class="fw-black mb-0">Payment History</h1><p class="text-muted mb-0">All your medical payment records</p></div>
    </div>

    @if (TempData["PaySuccess"] != null)
    {
        <div class="alert alert-success rounded-3 mb-4"><i class="bi bi-check-circle me-2"></i>@TempData["PaySuccess"]</div>
    }

    @if (!items.Any())
    {
        <div class="empty-state text-center py-5">
            <i class="bi bi-receipt-cutoff display-3 text-muted d-block mb-3"></i>
            <h5 class="text-muted">No payments yet</h5>
        </div>
    }
    else
    {
        <div class="content-card">
            <div class="table-responsive">
                <table class="table table-hover align-middle custom-table mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Doctor</th>
                            <th>Appointment</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th class="text-end">Receipt</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in items)
                        {
                            var pay  = (proekt.Models.Payment)item.Payment;
                            var doc  = item.Doctor as proekt.Models.User;
                            var appt = item.Appointment as proekt.Models.Appointment;
                            <tr>
                                <td><small>@pay.CreatedAt.ToString("dd MMM yyyy")</small></td>
                                <td><strong>Dr. @(doc?.FullName ?? "N/A")</strong></td>
                                <td><small>@(appt?.AppointmentDate.ToString("dd MMM HH:mm") ?? "—")</small></td>
                                <td><strong>@pay.Amount.ToString("F2") @pay.Currency</strong></td>
                                <td>
                                    <span class="badge rounded-pill px-3 @(pay.Status == proekt.Models.PaymentStatus.Paid ? "bg-success-soft text-success" : pay.Status == proekt.Models.PaymentStatus.Refunded ? "bg-warning-soft text-warning" : "bg-danger-soft text-danger")" style="font-size:0.7rem">@pay.Status</span>
                                </td>
                                <td class="text-end">
                                    @if (pay.Status == proekt.Models.PaymentStatus.Paid)
                                    {
                                        <a asp-controller="Payment" asp-action="Receipt" asp-route-id="@pay.Id"
                                           class="btn btn-outline-primary btn-sm rounded-pill px-3">Receipt</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
</div>
<style>
.fw-black { font-weight:900; }
.icon-badge { width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center; }
.bg-primary-soft { background:rgba(0,82,204,0.1); } .bg-success-soft { background:rgba(22,163,74,0.12); }
.bg-danger-soft { background:rgba(220,38,38,0.1); } .bg-warning-soft { background:rgba(245,158,11,0.12); }
.content-card { background:white;border-radius:20px;box-shadow:0 10px 30px rgba(0,0,0,0.04);border:1px solid #edf2f7;overflow:hidden; }
.custom-table th { font-size:0.72rem;text-transform:uppercase;letter-spacing:.05em;color:#94a3b8;border-bottom-width:1px;padding:1rem 1.25rem; }
.custom-table td { padding:1rem 1.25rem;border-bottom:1px solid #f1f5f9; }
</style>
