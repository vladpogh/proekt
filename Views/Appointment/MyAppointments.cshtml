@inject proekt.Services.TranslationService Loc
@{
    ViewData["Title"] = "My Appointments";
    var items = ViewBag.Items as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="appt-page py-5">
    <div class="container">
        <div class="d-flex align-items-center gap-3 mb-5">
            <div class="icon-badge bg-primary-soft fs-4"><i class="bi bi-calendar2-heart text-primary"></i></div>
            <div>
                <h1 class="fw-black mb-0">My Appointments</h1>
                <p class="text-muted mb-0">Track all your scheduled visits</p>
            </div>
            <a asp-controller="Home" asp-action="Doctors" class="btn btn-primary ms-auto rounded-pill px-4">
                <i class="bi bi-plus-lg me-2"></i>Book New
            </a>
        </div>

        @if (TempData["ApptSuccess"] != null)
        {
            <div class="alert alert-success rounded-3 mb-4">
                <i class="bi bi-check-circle me-2"></i>@TempData["ApptSuccess"]
            </div>
        }

        @if (!items.Any())
        {
            <div class="empty-state text-center py-5">
                <i class="bi bi-calendar-x display-3 text-muted d-block mb-3"></i>
                <h5 class="text-muted">No appointments yet</h5>
                <p class="text-muted small">Browse our doctors and book your first visit.</p>
                <a asp-controller="Home" asp-action="Doctors" class="btn btn-primary rounded-pill px-4 mt-2">Find a Doctor</a>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var item in items)
                {
                    var appt    = (proekt.Models.Appointment)item.Appointment;
                    var doctor  = item.Doctor as proekt.Models.User;
                    var payment = item.Payment as proekt.Models.Payment;
                    var statusClass = appt.Status switch
                    {
                        proekt.Models.AppointmentStatus.Confirmed  => "bg-success-soft text-success",
                        proekt.Models.AppointmentStatus.Cancelled  => "bg-danger-soft text-danger",
                        proekt.Models.AppointmentStatus.Completed  => "bg-primary-soft text-primary",
                        _ => "bg-warning-soft text-warning"
                    };

                    <div class="col-12">
                        <div class="appt-card p-4 d-flex align-items-center gap-4">
                            <div class="appt-date-block">
                                <div class="appt-day">@appt.AppointmentDate.ToString("dd")</div>
                                <div class="appt-month">@appt.AppointmentDate.ToString("MMM")</div>
                                <div class="appt-time">@appt.AppointmentDate.ToString("HH:mm")</div>
                            </div>
                            <div class="flex-grow-1">
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <h6 class="fw-bold mb-0">Dr. @(doctor?.FullName ?? "N/A")</h6>
                                    <span class="badge rounded-pill px-3 py-1 @statusClass" style="font-size:0.7rem">@appt.Status</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(appt.PatientNotes))
                                {
                                    <p class="text-muted small mb-1"><i class="bi bi-chat-left-text me-1"></i>@appt.PatientNotes</p>
                                }
                                @if (payment != null)
                                {
                                    <span class="badge bg-light text-dark border" style="font-size:0.7rem">
                                        <i class="bi bi-credit-card me-1"></i>@payment.Amount.ToString("F2") BGN — @payment.Status
                                    </span>
                                }
                            </div>
                            <div class="d-flex flex-column gap-2 align-items-end">
                                <a asp-controller="Appointment" asp-action="Details" asp-route-id="@appt.Id"
                                   class="btn btn-outline-primary btn-sm rounded-pill px-3">Details</a>

                                @if (appt.Status == proekt.Models.AppointmentStatus.Completed && payment == null)
                                {
                                    <a asp-controller="Payment" asp-action="Initiate" asp-route-appointmentId="@appt.Id"
                                       class="btn btn-success btn-sm rounded-pill px-3">
                                        <i class="bi bi-credit-card me-1"></i>Pay
                                    </a>
                                }
                                @if (appt.Status == proekt.Models.AppointmentStatus.Pending || appt.Status == proekt.Models.AppointmentStatus.Confirmed)
                                {
                                    <form asp-controller="Appointment" asp-action="Cancel" method="post" class="d-inline"
                                          onsubmit="return confirm('Cancel this appointment?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@appt.Id" />
                                        <button class="btn btn-outline-danger btn-sm rounded-pill px-3">Cancel</button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
.appt-page { background: #f8faff; min-height: calc(100vh - 100px); }
.fw-black { font-weight: 900; }
.icon-badge { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; }
.bg-primary-soft { background: rgba(0,82,204,0.1); }
.bg-success-soft { background: rgba(22,163,74,0.12); }
.bg-danger-soft  { background: rgba(220,38,38,0.1); }
.bg-warning-soft { background: rgba(245,158,11,0.12); }
.appt-card { background: white; border-radius: 16px; box-shadow: 0 4px 16px rgba(0,0,0,0.04); border: 1px solid #edf2f7; transition: all 0.2s; }
.appt-card:hover { box-shadow: 0 8px 24px rgba(0,82,204,0.1); border-color: #c7d7f5; }
.appt-date-block { background: #f8faff; border-radius: 12px; padding: 0.75rem 1.25rem; text-align: center; min-width: 72px; border: 1px solid #edf2f7; }
.appt-day   { font-size: 1.8rem; font-weight: 800; color: #0052CC; line-height: 1; }
.appt-month { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; color: #64748b; letter-spacing: 0.05em; }
.appt-time  { font-size: 0.75rem; font-weight: 600; color: #94a3b8; margin-top: 2px; }
</style>
