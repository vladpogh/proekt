@inject proekt.Services.TranslationService Loc
@{
    ViewData["Title"] = "Book Appointment";
    var doctor  = ViewBag.Doctor  as proekt.Models.User;
    var profile = ViewBag.Profile as proekt.Models.DoctorProfile;
    var doctorId = doctor?.Id ?? 0;
    var slots   = ViewBag.Slots  as List<DateTime> ?? new List<DateTime>();
    var dateStr = ViewBag.Date as string ?? DateTime.Today.ToString("yyyy-MM-dd");
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="book-page py-5">
    <div class="container">
        <div class="row g-4">
            <!-- Doctor Info Card -->
            <div class="col-lg-4">
                <div class="doctor-card-sidebar p-4 h-100">
                    <div class="doctor-avatar-lg mx-auto mb-3">
                        @(doctor?.FullName?.Substring(0,1).ToUpper() ?? "D")
                    </div>
                    <h4 class="text-center fw-bold mb-1">Dr. @doctor?.FullName</h4>
                    <p class="text-center text-primary fw-semibold mb-3">@(profile?.Specialization ?? "General Practitioner")</p>

                    <div class="info-row"><i class="bi bi-cash-coin text-success"></i> <span>@((profile?.ConsultationFee ?? 50m).ToString("F2")) BGN / visit</span></div>
                    <div class="info-row"><i class="bi bi-clock text-primary"></i>
                        <span>
                            @{ var f = profile?.AvailableFromMinutes ?? 480; var t = profile?.AvailableToMinutes ?? 1020; }
                            @($"{f/60:D2}:{f%60:D2}") – @($"{t/60:D2}:{t%60:D2}")
                        </span>
                    </div>
                    <div class="info-row"><i class="bi bi-calendar-week text-warning"></i>
                        <span>@(profile?.WorkingDays == "1,2,3,4,5" ? "Mon – Fri" : profile?.WorkingDays ?? "Mon – Fri")</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(profile?.Bio))
                    {
                        <hr>
                        <p class="text-muted small">@profile.Bio</p>
                    }
                </div>
            </div>

            <!-- Booking Form -->
            <div class="col-lg-8">
                <div class="content-card p-4">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="icon-badge bg-primary-soft"><i class="bi bi-calendar-plus text-primary"></i></div>
                        <div>
                            <h5 class="fw-bold mb-0">Book an Appointment</h5>
                            <p class="text-muted small mb-0">Select a date and an available time slot</p>
                        </div>
                    </div>

                    @if (TempData["ApptError"] != null)
                    {
                        <div class="alert alert-danger rounded-3">@TempData["ApptError"]</div>
                    }

                    <!-- Date picker -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Select Date</label>
                        <input type="date" id="apptDate" class="form-control rounded-3"
                               value="@dateStr" min="@DateTime.Today.ToString("yyyy-MM-dd")"
                               onchange="loadSlots(this.value)">
                    </div>

                    <!-- Time slots -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Available Time Slots</label>
                        <div id="slots-container" class="d-flex flex-wrap gap-2">
                            @foreach (var slot in slots)
                            {
                                <button type="button" class="slot-btn" onclick="selectSlot(this, '@slot.ToString("HH:mm")')">
                                    @slot.ToString("HH:mm")
                                </button>
                            }
                            @if (!slots.Any())
                            {
                                <p class="text-muted" id="no-slots-msg">No slots available for this date.</p>
                            }
                        </div>
                    </div>

                    <!-- Booking form -->
                    <form asp-controller="Appointment" asp-action="Book" method="post" id="bookForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="doctorId" value="@doctorId" />
                        <input type="hidden" name="date" id="hiddenDate" value="@dateStr" />
                        <input type="hidden" name="time" id="hiddenTime" value="" />

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Notes for Doctor <span class="text-muted fw-normal">(optional)</span></label>
                            <textarea name="notes" class="form-control rounded-3" rows="3" placeholder="Describe your symptoms or reason for visit..."></textarea>
                        </div>

                        <div class="selected-slot-display mb-4 d-none" id="selectionDisplay">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>
                            <span>Selected: <strong id="selectionText"></strong></span>
                        </div>

                        <button type="submit" class="btn btn-primary px-5 py-2 rounded-pill" id="submitBtn" disabled>
                            <i class="bi bi-calendar-check me-2"></i>Confirm Booking
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.book-page { background: #f8faff; min-height: calc(100vh - 100px); }
.doctor-card-sidebar { background: white; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.06); border: 1px solid #edf2f7; }
.doctor-avatar-lg { width: 80px; height: 80px; background: linear-gradient(135deg,#0052CC,#0073e6); color: white; font-size: 2rem; font-weight: 800; border-radius: 20px; display: flex; align-items: center; justify-content: center; }
.info-row { display: flex; align-items: center; gap: 0.6rem; padding: 0.5rem 0; border-bottom: 1px solid #f1f5f9; font-size: 0.9rem; }
.info-row:last-child { border-bottom: none; }
.content-card { background: white; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.04); border: 1px solid #edf2f7; }
.icon-badge { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
.bg-primary-soft { background: rgba(0,82,204,0.1); }
.slot-btn { padding: 0.5rem 1.1rem; border: 2px solid #e2e8f0; border-radius: 10px; background: white; font-weight: 600; font-size: 0.9rem; cursor: pointer; transition: all 0.2s; color: #334155; }
.slot-btn:hover { border-color: #0052CC; color: #0052CC; background: rgba(0,82,204,0.05); }
.slot-btn.selected { background: #0052CC; color: white; border-color: #0052CC; }
.selected-slot-display { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 10px; padding: 0.75rem 1rem; }
</style>

@section Scripts {
<script>
function loadSlots(date) {
    const doctorId = @doctorId;
    document.getElementById('hiddenDate').value = date;
    document.getElementById('slots-container').innerHTML = '<div class="text-muted">Loading...</div>';
    fetch(`/Appointment/GetSlots?doctorId=${doctorId}&date=${date}`)
        .then(r => r.json())
        .then(slots => {
            const c = document.getElementById('slots-container');
            if (!slots.length) { c.innerHTML = '<p class="text-muted">No slots available for this date.</p>'; return; }
            c.innerHTML = slots.map(s =>
                `<button type="button" class="slot-btn" onclick="selectSlot(this,'${s}')">${s}</button>`
            ).join('');
            // Reset selection
            document.getElementById('hiddenTime').value = '';
            document.getElementById('submitBtn').disabled = true;
            document.getElementById('selectionDisplay').classList.add('d-none');
        });
}

function selectSlot(btn, time) {
    document.querySelectorAll('.slot-btn').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
    document.getElementById('hiddenTime').value = time;
    document.getElementById('submitBtn').disabled = false;
    const display = document.getElementById('selectionDisplay');
    display.classList.remove('d-none');
    const date = document.getElementById('hiddenDate').value;
    document.getElementById('selectionText').textContent = `${date} at ${time}`;
}
</script>
}
