@model proekt.Models.Appointment
@{
    ViewData["Title"] = "Appointment Details";
    var doctor  = ViewBag.Doctor  as proekt.Models.User;
    var patient = ViewBag.Patient as proekt.Models.User;
    var payment = ViewBag.Payment as proekt.Models.Payment;
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<div class="py-5" style="background:#f8faff;min-height:calc(100vh - 100px)">
<div class="container" style="max-width:700px">
    <div class="content-card p-4">
        <div class="d-flex align-items-center gap-3 mb-4">
            <div class="icon-badge bg-primary-soft fs-4"><i class="bi bi-calendar-event text-primary"></i></div>
            <h4 class="fw-bold mb-0">Appointment Details</h4>
        </div>
        <div class="row g-3 mb-4">
            <div class="col-6"><div class="detail-row"><span class="detail-label">Date &amp; Time</span><span class="detail-value">@Model.AppointmentDate.ToString("dddd, dd MMM yyyy HH:mm")</span></div></div>
            <div class="col-6"><div class="detail-row"><span class="detail-label">Status</span><span class="badge rounded-pill px-3 py-2 @(Model.Status == proekt.Models.AppointmentStatus.Completed ? "bg-primary-soft text-primary" : Model.Status == proekt.Models.AppointmentStatus.Cancelled ? "bg-danger-soft text-danger" : Model.Status == proekt.Models.AppointmentStatus.Confirmed ? "bg-success-soft text-success" : "bg-warning-soft text-warning")">@Model.Status</span></div></div>
            <div class="col-6"><div class="detail-row"><span class="detail-label">Patient</span><span class="detail-value">@(patient?.FullName ?? "N/A")</span></div></div>
            <div class="col-6"><div class="detail-row"><span class="detail-label">Doctor</span><span class="detail-value">Dr. @(doctor?.FullName ?? "N/A")</span></div></div>
            @if (!string.IsNullOrWhiteSpace(Model.PatientNotes))
            {
                <div class="col-12"><div class="detail-row"><span class="detail-label">Patient Notes</span><span class="detail-value">@Model.PatientNotes</span></div></div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.DoctorNotes))
            {
                <div class="col-12"><div class="detail-row"><span class="detail-label">Doctor Notes</span><span class="detail-value">@Model.DoctorNotes</span></div></div>
            }
        </div>
        @if (payment != null)
        {
            <div class="payment-summary p-3 rounded-3 mb-4">
                <h6 class="fw-bold mb-2"><i class="bi bi-credit-card me-2 text-success"></i>Payment</h6>
                <div class="row g-2">
                    <div class="col-4"><small class="text-muted d-block">Amount</small><strong>@payment.Amount.ToString("F2") EUR</strong></div>
                    <div class="col-4"><small class="text-muted d-block">Status</small><span class="badge @(payment.Status == proekt.Models.PaymentStatus.Paid ? "bg-success" : "bg-warning text-dark")">@payment.Status</span></div>
                    @if (payment.PaidAt.HasValue) {
                        <div class="col-4"><small class="text-muted d-block">Paid At</small><strong>@payment.PaidAt.Value.ToString("dd MMM HH:mm")</strong></div>
                    }
                </div>
            </div>
        }
        <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-2"></i>Back
        </a>
    </div>
</div>
</div>
<style>
.content-card { background:white; border-radius:20px; box-shadow:0 10px 30px rgba(0,0,0,0.04); border:1px solid #edf2f7; }
.icon-badge { width:48px; height:48px; border-radius:12px; display:flex; align-items:center; justify-content:center; }
.bg-primary-soft { background:rgba(0,82,204,0.1); } .bg-success-soft { background:rgba(22,163,74,0.12); }
.bg-danger-soft  { background:rgba(220,38,38,0.1); } .bg-warning-soft { background:rgba(245,158,11,0.12); }
.detail-row { display:flex; flex-direction:column; gap:2px; }
.detail-label { font-size:0.75rem; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; color:#94a3b8; }
.detail-value { font-weight:600; color:#1e293b; }
.payment-summary { background:#f0fdf4; border:1px solid #bbf7d0; }
</style>
