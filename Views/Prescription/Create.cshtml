@{
    ViewData["Title"] = "Create Prescription";
    var patient = ViewBag.Patient as proekt.Models.User;
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<div class="py-5" style="background:#f8faff;min-height:calc(100vh - 100px)">
<div class="container" style="max-width:750px">
    <div class="content-card p-4">
        <div class="d-flex align-items-center gap-3 mb-4">
            <div class="icon-badge bg-primary-soft fs-4"><i class="bi bi-file-medical text-primary"></i></div>
            <div>
                <h4 class="fw-bold mb-0">Issue Prescription</h4>
                <p class="text-muted small mb-0">For: <strong>@patient?.FullName</strong> (@patient?.Email)</p>
            </div>
        </div>

        @if (TempData["RxSuccess"] != null)
        {
            <div class="alert alert-success rounded-3 mb-3"><i class="bi bi-check-circle me-2"></i>@TempData["RxSuccess"]</div>
        }

        <form asp-controller="Prescription" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="patientId" value="@patient?.Id" />

            <div class="mb-3">
                <label class="form-label fw-semibold">Diagnosis <span class="text-danger">*</span></label>
                <input type="text" name="diagnosis" class="form-control rounded-3" placeholder="e.g. Acute Bronchitis" required />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Medications <span class="text-danger">*</span></label>
                <textarea name="medications" class="form-control rounded-3" rows="4"
                    placeholder="e.g.&#10;Amoxicillin 500mg – 3x daily for 7 days&#10;Ibuprofen 400mg – as needed for pain" required></textarea>
                <div class="form-text">List each medication on a new line.</div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Instructions</label>
                <textarea name="instructions" class="form-control rounded-3" rows="2"
                    placeholder="e.g. Take with food. Rest and drink plenty of fluids."></textarea>
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">Expires On</label>
                <input type="date" name="expiresAt" class="form-control rounded-3"
                       min="@DateTime.Today.ToString("yyyy-MM-dd")"
                       value="@DateTime.Today.AddMonths(1).ToString("yyyy-MM-dd")" />
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary rounded-pill px-5">
                    <i class="bi bi-file-earmark-check me-2"></i>Issue Prescription
                </button>
                <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
            </div>
        </form>
    </div>
</div>
</div>
<style>
.content-card { background:white; border-radius:20px; box-shadow:0 10px 30px rgba(0,0,0,0.04); border:1px solid #edf2f7; }
.icon-badge { width:48px; height:48px; border-radius:12px; display:flex; align-items:center; justify-content:center; }
.bg-primary-soft { background:rgba(0,82,204,0.1); }
</style>
