@{
    ViewData["Title"] = "Issued Prescriptions";
    var items = ViewBag.Items as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<div class="py-5" style="background:#f8faff;min-height:calc(100vh - 100px)">
<div class="container">
    <div class="d-flex align-items-center gap-3 mb-5">
        <div class="icon-badge bg-primary-soft fs-4"><i class="bi bi-file-medical-fill text-primary"></i></div>
        <div><h1 class="fw-black mb-0">Issued Prescriptions</h1><p class="text-muted mb-0">All prescriptions you have issued</p></div>
    </div>

    @if (!items.Any())
    {
        <div class="empty-state text-center py-5">
            <i class="bi bi-file-x display-3 text-muted d-block mb-3"></i>
            <h5 class="text-muted">No prescriptions issued yet</h5>
        </div>
    }
    else
    {
        <div class="content-card">
            <div class="table-responsive">
                <table class="table table-hover align-middle custom-table mb-0">
                    <thead>
                        <tr>
                            <th>Patient</th>
                            <th>Diagnosis</th>
                            <th>Issued</th>
                            <th>Expires</th>
                            <th>Status</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in items)
                        {
                            var rx      = (proekt.Models.Prescription)item.Prescription;
                            var patient = item.Patient as proekt.Models.User;
                            var expired = rx.ExpiresAt.HasValue && rx.ExpiresAt.Value < DateTime.Today;
                            <tr>
                                <td>
                                    <div class="fw-bold">@(patient?.FullName ?? "N/A")</div>
                                    <small class="text-muted">@patient?.Email</small>
                                </td>
                                <td>@rx.Diagnosis</td>
                                <td><small>@rx.IssuedAt.ToString("dd MMM yyyy")</small></td>
                                <td><small class="@(expired ? "text-danger fw-semibold" : "")">@(rx.ExpiresAt?.ToString("dd MMM yyyy") ?? "—")</small></td>
                                <td>
                                    <span class="badge rounded-pill px-3 @(expired ? "bg-danger-soft text-danger" : rx.IsActive ? "bg-success-soft text-success" : "bg-secondary text-white")" style="font-size:0.7rem">
                                        @(expired ? "Expired" : rx.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a asp-controller="Prescription" asp-action="Details" asp-route-id="@rx.Id"
                                       class="btn btn-outline-primary btn-sm rounded-pill px-3">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
</div>
<style>
.fw-black { font-weight:900; }
.icon-badge { width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center; }
.bg-primary-soft { background:rgba(0,82,204,0.1); } .bg-success-soft { background:rgba(22,163,74,0.12); } .bg-danger-soft { background:rgba(220,38,38,0.1); }
.content-card { background:white;border-radius:20px;box-shadow:0 10px 30px rgba(0,0,0,0.04);border:1px solid #edf2f7;overflow:hidden; }
.custom-table th { font-size:0.72rem;text-transform:uppercase;letter-spacing:.05em;color:#94a3b8;border-bottom-width:1px;padding:1rem 1.25rem; }
.custom-table td { padding:1rem 1.25rem;border-bottom:1px solid #f1f5f9; }
</style>
