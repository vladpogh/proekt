@inject proekt.Services.TranslationService Loc
@{
    ViewData["Title"] = Loc.T("DoctorApplication");
}

<div style="min-height: 80vh; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #f8faff 0%, #ffffff 100%); padding: 40px 20px;">
    <div style="width: 100%; max-width: 800px; background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); border-radius: 1.5rem; border: 1px solid rgba(229, 231, 235, 0.5); padding: 3rem; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.02);">
        
        <!-- Header Section -->
        <div style="text-align: center; margin-bottom: 3rem;">
            <div style="width: 70px; height: 70px; background: #0052CC; border-radius: 20px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; transform: rotate(-5deg); box-shadow: 0 10px 15px -3px rgba(0, 82, 204, 0.3);">
                <i class="bi bi-clipboard2-pulse" style="font-size: 2rem; color: white;"></i>
            </div>
            <h1 style="font-size: 2rem; font-weight: 800; color: #111827; margin: 0; letter-spacing: -0.025em;">@Loc.T("DoctorApplication")</h1>
            <p style="color: #6B7280; max-width: 500px; margin: 1rem auto 0; font-size: 1.1rem; line-height: 1.5;">@Loc.T("AppDescription")</p>
        </div>

        <!-- Application Form -->
        <form asp-action="DoctorApplication" method="post" enctype="multipart/form-data" style="display: flex; flex-direction: column; gap: 2rem;">
            
            <!-- Experience / About Section -->
            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                <label for="about" style="font-weight: 700; color: #374151; font-size: 0.95rem; display: flex; align-items: center; gap: 0.5rem;">
                    <i class="bi bi-person-lines-fill" style="color: #0052CC;"></i> @Loc.T("TellUsMore")
                </label>
                <textarea id="about" name="about" rows="4" required 
                          style="width: 100%; padding: 1rem; border: 1px solid #E5E7EB; border-radius: 0.75rem; font-family: inherit; font-size: 1rem; transition: all 0.2s; outline: none; resize: none; background: #F9FAFB;"
                          placeholder="Please provide a brief overview of your medical background and experience..."></textarea>
            </div>

            <!-- Documents Section -->
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem;">
                
                <!-- Employment Contract -->
                <div class="file-upload-container">
                    <label style="display: block; font-weight: 700; color: #374151; font-size: 0.85rem; margin-bottom: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;">@Loc.T("EmploymentContract")</label>
                    <div class="upload-area" onclick="document.getElementById('employmentContract').click()">
                        <div class="upload-icon"><i class="bi bi-file-earmark-text"></i></div>
                        <div class="upload-text">@Loc.T("FileUpload")</div>
                        <div class="upload-hint">@Loc.T("FileRequired")</div>
                        <input type="file" id="employmentContract" name="employmentContract" style="display: none;" required onchange="updateFileName(this)" />
                        <div class="file-name"></div>
                    </div>
                </div>

                <!-- ID Card -->
                <div class="file-upload-container">
                    <label style="display: block; font-weight: 700; color: #374151; font-size: 0.85rem; margin-bottom: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;">@Loc.T("IDCard")</label>
                    <div class="upload-area" onclick="document.getElementById('idCard').click()">
                        <div class="upload-icon"><i class="bi bi-person-badge"></i></div>
                        <div class="upload-text">@Loc.T("FileUpload")</div>
                        <div class="upload-hint">@Loc.T("FileRequired")</div>
                        <input type="file" id="idCard" name="idCard" style="display: none;" required onchange="updateFileName(this)" />
                        <div class="file-name"></div>
                    </div>
                </div>

                <!-- Medical License -->
                <div class="file-upload-container">
                    <label style="display: block; font-weight: 700; color: #374151; font-size: 0.85rem; margin-bottom: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;">@Loc.T("MedicalLicense")</label>
                    <div class="upload-area" onclick="document.getElementById('medicalLicense').click()">
                        <div class="upload-icon"><i class="bi bi-patch-check"></i></div>
                        <div class="upload-text">@Loc.T("FileUpload")</div>
                        <div class="upload-hint">@Loc.T("FileRequired")</div>
                        <input type="file" id="medicalLicense" name="medicalLicense" style="display: none;" required onchange="updateFileName(this)" />
                        <div class="file-name"></div>
                    </div>
                </div>

            </div>

            <!-- Submit Button -->
            <button type="submit" style="width: 100%; padding: 1.25rem; background: #0052CC; color: white; border: none; border-radius: 1rem; font-weight: 700; font-size: 1.1rem; cursor: pointer; transition: all 0.3s; margin-top: 1rem; display: flex; align-items: center; justify-content: center; gap: 0.75rem; box-shadow: 0 4px 6px -1px rgba(0, 82, 204, 0.2);">
                <span>@Loc.T("SubmitApplication")</span>
                <i class="bi bi-arrow-right"></i>
            </button>
        </form>
    </div>
</div>

<style>
    .upload-area {
        border: 2px dashed #E5E7EB;
        border-radius: 1rem;
        padding: 1.5rem;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        background: #F9FAFB;
        position: relative;
    }

    .upload-area:hover {
        border-color: #0052CC;
        background: #F0F7FF;
        transform: translateY(-2px);
    }

    .upload-icon {
        font-size: 1.5rem;
        color: #9CA3AF;
        margin-bottom: 0.5rem;
        transition: color 0.3s;
    }

    .upload-area:hover .upload-icon {
        color: #0052CC;
    }

    .upload-text {
        font-size: 0.85rem;
        font-weight: 600;
        color: #4B5563;
        margin-bottom: 0.25rem;
    }

    .upload-hint {
        font-size: 0.7rem;
        color: #9CA3AF;
    }

    textarea:focus {
        border-color: #0052CC;
        background: white;
        box-shadow: 0 0 0 4px rgba(0, 82, 204, 0.1);
    }

    .file-name {
        margin-top: 0.5rem;
        font-size: 0.75rem;
        color: #0052CC;
        font-weight: 600;
        word-break: break-all;
    }

    button:hover {
        background: #0045B5;
        transform: translateY(-2px);
        box-shadow: 0 10px 15px -3px rgba(0, 82, 204, 0.3);
    }

    button:active {
        transform: translateY(0);
    }
</style>

<script>
    function updateFileName(input) {
        const area = input.parentElement;
        const nameDisplay = area.querySelector('.file-name');
        const icon = area.querySelector('.bi');
        
        if (input.files && input.files.length > 0) {
            nameDisplay.textContent = '✓ ' + input.files[0].name;
            area.style.borderColor = '#059669';
            area.style.background = '#ECFDF5';
            icon.style.color = '#059669';
        } else {
            nameDisplay.textContent = '';
            area.style.borderColor = '#E5E7EB';
            area.style.background = '#F9FAFB';
            icon.style.color = '#9CA3AF';
        }
    }
</script>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
