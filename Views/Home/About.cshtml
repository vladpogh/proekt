@{
    ViewData["Title"] = "За нас - MedReports";
}

<!-- About Hero Section -->
<div class="container-fluid px-0">
    <div style="background: linear-gradient(135deg, #f0f4ff 0%, #ffffff 100%); padding: 100px 40px; text-align: center;">
        <div class="container">
            <h1 style="font-size: 3.5rem; font-weight: 900; color: #000; margin-bottom: 1.5rem;">Нашата Мисия</h1>
            <p style="font-size: 1.25rem; color: #666; max-width: 800px; margin: 0 auto; line-height: 1.6;">
                Ние в MedReports вярваме, че достъпът до здравеопазване трябва да бъде лесен, сигурен и дигитализиран. 
                Нашата цел е да преобразим начина, по който пациентите и лекарите взаимодействат, чрез иновативни технологични решения.
            </p>
        </div>
    </div>
</div>

<!-- Our Story Section -->
<div class="container py-5">
    <div class="row align-items-center">
        <div class="col-lg-6">
            <h2 style="font-size: 2.5rem; font-weight: 900; margin-bottom: 2rem;">Нашата История</h2>
            <p style="color: #4b5563; line-height: 1.8; margin-bottom: 1.5rem; font-size: 1.1rem;">
                Основана през 2024 година, MedReports започна като малка инициатива с една визия: да сложи край на хартиената документация в болниците. 
                Днес ние обслужваме хиляди пациенти и лекари в цялата страна, предлагайки платформа, която е едновременно мощна и лесна за употреба.
            </p>
            <p style="color: #4b5563; line-height: 1.8; font-size: 1.1rem;">
                Всяка функция в нашата система е разработена с мисъл за крайния потребител, преминавайки през строги тестове за сигурност и качество.
            </p>
        </div>
        <div class="col-lg-6 text-center">
            <img src="/images/about-hero.png" alt="MedReports Story" style="width: 100%; max-width: 500px; border-radius: 1rem; box-shadow: 0 20px 40px rgba(0,0,0,0.1);">
        </div>
    </div>
</div>

<!-- Core Values Section -->
<div class="container-fluid px-0" style="background-color: #f8fafc; padding: 80px 40px;">
    <div class="container text-center">
        <h2 style="font-size: 2.5rem; font-weight: 900; margin-bottom: 4rem;">Нашите Ценности</h2>
        <div class="row">
            <div class="col-md-4 mb-4">
                <div style="background: white; padding: 3rem 2rem; border-radius: 1rem; box-shadow: 0 4px 6px rgba(0,0,0,0.05); height: 100%;">
                    <div style="width: 64px; height: 64px; background: rgba(59, 130, 246, 0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 2L3 7V12C3 17.41 6.84 22.38 12 24C17.16 22.38 21 17.41 21 12V7L12 2Z" fill="#3b82f6"/>
                        </svg>
                    </div>
                    <h3 style="font-weight: 700; margin-bottom: 1rem;">Сигурност</h3>
                    <p style="color: #666;">Вашите данни са защитени с най-модерните методи за криптиране и сигурност.</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div style="background: white; padding: 3rem 2rem; border-radius: 1rem; box-shadow: 0 4px 6px rgba(0,0,0,0.05); height: 100%;">
                    <div style="width: 64px; height: 64px; background: rgba(16, 185, 129, 0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M13 3L4 14H11V21L20 10H13V3Z" fill="#10b981"/>
                        </svg>
                    </div>
                    <h3 style="font-weight: 700; margin-bottom: 1rem;">Иновация</h3>
                    <p style="color: #666;">Ние непрекъснато подобряваме нашите продукти според последните тенденции в технологиите.</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div style="background: white; padding: 3rem 2rem; border-radius: 1rem; box-shadow: 0 4px 6px rgba(0,0,0,0.05); height: 100%;">
                    <div style="width: 64px; height: 64px; background: rgba(245, 158, 11, 0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 17.27L18.18 21L16.54 13.97L22 9.24L14.81 8.63L12 2L9.19 8.63L2 9.24L7.46 13.97L5.82 21L12 17.27Z" fill="#f59e0b"/>
                        </svg>
                    </div>
                    <h3 style="font-weight: 700; margin-bottom: 1rem;">Качество</h3>
                    <p style="color: #666;">Предоставяме най-доброто потребителско изживяване за медицинска администрация.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- CTA Section -->
<div class="container py-8 text-center" style="padding: 100px 0;">
    <h2 style="font-size: 2.5rem; font-weight: 900; margin-bottom: 2rem;">Готови ли сте да започнете?</h2>
    <p style="font-size: 1.1rem; color: #666; margin-bottom: 3rem;">Присъединете се към хилядите доволни потребители днес.</p>
    <div class="d-flex justify-content-center gap-3">
        <a asp-action="Register" class="btn btn-primary btn-lg" style="padding: 1rem 3rem; border-radius: 0.5rem; font-weight: 600;">Регистрация</a>
        <a asp-action="Contact" class="btn btn-outline-primary btn-lg" style="padding: 1rem 3rem; border-radius: 0.5rem; font-weight: 600;">Контакти</a>
    </div>
</div>
