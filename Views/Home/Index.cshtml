@inject proekt.Services.TranslationService Loc
@{
    ViewData["Title"] = "MedReports - " + Loc.T("Home");
    var medicalHeroImage = "/images/medical_hero.png";
}

<!-- Hero Section -->
<section class="hp-hero">
    <div class="container hp-hero-content">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0">
                <div class="hp-badge">
                    <i class="bi bi-patch-check-fill text-primary"></i>
                    <span class="text-primary fw-bold">@Loc.T("Index_HeroBadge")</span>
                </div>
                
                <h1 class="hp-title">
                    @Html.Raw(Loc.T("Index_HeroTitle"))
                </h1>
                <p class="hp-desc mb-5">
                    @Loc.T("Index_HeroDesc")
                </p>
                <div class="d-flex flex-wrap gap-3">
                    <a asp-controller="MedicalRecord" asp-action="ViewRecord" asp-route-userId="@Context.Session.GetInt32("UserId")" 
                       class="btn btn-primary btn-lg px-5 py-3 rounded-pill fw-bold shadow-sm hover-lift d-flex align-items-center gap-2">
                        @Loc.T("Index_ShowRecord")
                        <i class="bi bi-arrow-right"></i>
                    </a>
                    <a asp-controller="Home" asp-action="Contact" 
                       class="btn btn-outline-primary btn-lg px-5 py-3 rounded-pill fw-bold hover-lift">
                        @Loc.T("Index_ContactUs")
                    </a>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hp-hero-img-container">
                    <img src="@medicalHeroImage" alt="Advanced Medical System" class="img-fluid">
                    <!-- Floating Stat Detail -->
                    <div class="position-absolute bottom-0 start-0 bg-white p-3 rounded-4 shadow-lg m-4 d-none d-md-flex align-items-center gap-3 border border-light">
                        <div class="bg-success-soft text-success rounded-circle p-2">
                            <i class="bi bi-shield-lock-fill fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-black text-dark mb-0">100% Secure</div>
                            <small class="text-muted">HIPAA Compliant</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Advantages Section -->
<section class="py-5" style="background: #fff;">
    <div class="container py-5">
        <h2 class="hp-section-title">
            @Loc.T("Index_Adv_Title")
        </h2>
        
        <div class="hp-feature-grid">
            <div class="hp-feature-card">
                <div class="hp-feature-icon">
                    <i class="bi bi-lightning-charge"></i>
                </div>
                <h4 class="fw-bold mb-3">@Loc.T("Index_Adv_1")</h4>
                <p class="text-muted mb-0">Experience lightning-fast access to your medical history anytime, anywhere in the world.</p>
            </div>

            <div class="hp-feature-card">
                <div class="hp-feature-icon">
                    <i class="bi bi-shield-check"></i>
                </div>
                <h4 class="fw-bold mb-3">@Loc.T("Index_Adv_2")</h4>
                <p class="text-muted mb-0">Your data is encrypted with military-grade protocols, ensuring your privacy is never compromised.</p>
            </div>

            <div class="hp-feature-card">
                <div class="hp-feature-icon">
                    <i class="bi bi-people"></i>
                </div>
                <h4 class="fw-bold mb-3">@Loc.T("Index_Adv_3")</h4>
                <p class="text-muted mb-0">Seamlessly share your reports with participating doctors and laboratories in one click.</p>
            </div>

            <div class="hp-feature-card">
                <div class="hp-feature-icon">
                    <i class="bi bi-cloud-arrow-up"></i>
                </div>
                <h4 class="fw-bold mb-3">@Loc.T("Index_Adv_4")</h4>
                <p class="text-muted mb-0">Never lose a physical document again. All your records are safely backed up in the cloud.</p>
            </div>

            <div class="hp-feature-card">
                <div class="hp-feature-icon">
                    <i class="bi bi-graph-up-arrow"></i>
                </div>
                <h4 class="fw-bold mb-3">@Loc.T("Index_Adv_5")</h4>
                <p class="text-muted mb-0">Track your health trends over time with integrated data visualizations and insights.</p>
            </div>

            <div class="hp-feature-card bg-primary text-white border-0">
                <div class="hp-feature-icon bg-white bg-opacity-20 text-white">
                    <i class="bi bi-plus-circle"></i>
                </div>
                <h4 class="fw-bold mb-3">Explore More</h4>
                <p class="text-white text-opacity-75 mb-4">Join thousands of users who trust MedReports with their healthcare journey.</p>
                <a asp-action="Register" class="btn btn-light rounded-pill px-4 fw-bold">Get Started</a>
            </div>
        </div>
    </div>
</section>

<!-- Stats Section -->
<section class="py-5 bg-light">
    <div class="container py-5">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="hp-stat-glass">
                    <div class="hp-stat-value">@(ViewBag.TotalRecords ?? 0)+</div>
                    <div class="hp-stat-label">@Loc.T("Index_Stats_Records")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="hp-stat-glass">
                    <div class="hp-stat-value">@(ViewBag.TotalDoctors ?? 0)+</div>
                    <div class="hp-stat-label">@Loc.T("Index_Stats_Doctors")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="hp-stat-glass">
                    <div class="hp-stat-value">@(ViewBag.TotalUsers ?? 0)+</div>
                    <div class="hp-stat-label">@Loc.T("Index_Stats_Users")</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Trust Section -->
<section class="py-5 bg-white">
    <div class="container text-center py-4">
        <p class="text-muted small text-uppercase fw-bold letter-spacing-2 mb-5">Trusted by leading medical institutions</p>
        <div class="row align-items-center justify-content-center hp-trust-logos g-4 g-lg-5">
            <div class="col-6 col-md-3">
                <div class="hp-trust-logo-card">
                    <img src="~/images/hospitals/pirogov_logo.png" alt="UMHATEM Pirogov">
                    <span class="d-block mt-2 small fw-bold text-muted">Pirogov</span>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="hp-trust-logo-card">
                    <img src="~/images/hospitals/alexandrovska_logo.png" alt="UMHAT Alexandrovska">
                    <span class="d-block mt-2 small fw-bold text-muted">Alexandrovska</span>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="hp-trust-logo-card">
                    <img src="~/images/hospitals/vma_logo.png" alt="Military Medical Academy">
                    <span class="d-block mt-2 small fw-bold text-muted">VMA Sofia</span>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="hp-trust-logo-card">
                    <img src="~/images/hospitals/tokuda_logo.png" alt="Acibadem City Clinic">
                    <span class="d-block mt-2 small fw-bold text-muted">Acibadem Tokuda</span>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
}
