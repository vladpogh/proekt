@inject proekt.Services.TranslationService Loc
@{
    ViewData["Title"] = "MedReports - " + Loc.T("Home");
    var medicalHeroImage = "/images/medical_hero.png";
}

<!-- Hero Section -->
<section class="hp-hero">
    <div class="container hp-hero-content">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0">
                <div class="hp-badge">
                    <i class="bi bi-patch-check-fill text-primary"></i>
                    <span class="text-primary fw-bold">@Loc.T("Index_HeroBadge")</span>
                </div>
                
                <h1 class="hp-title">
                    @Html.Raw(Loc.T("Index_HeroTitle"))
                </h1>
                <p class="hp-desc mb-5">
                    @Loc.T("Index_HeroDesc")
                </p>
                <div class="d-flex flex-wrap gap-3">
                    <a asp-controller="MedicalRecord" asp-action="ViewRecord" asp-route-userId="@Context.Session.GetInt32("UserId")" 
                       class="btn btn-primary btn-lg px-5 py-3 rounded-pill fw-bold shadow-sm hover-lift d-flex align-items-center gap-2">
                        @Loc.T("Index_ShowRecord")
                        <i class="bi bi-arrow-right"></i>
                    </a>
                    <a asp-controller="Home" asp-action="Contact" 
                       class="btn btn-outline-primary btn-lg px-5 py-3 rounded-pill fw-bold hover-lift">
                        @Loc.T("Index_ContactUs")
                    </a>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hp-hero-img-container">
                    <img src="@medicalHeroImage" alt="Advanced Medical System" class="img-fluid">
                    <!-- Floating Stat Detail -->
                    <div class="position-absolute bottom-0 start-0 bg-white p-3 rounded-4 shadow-lg m-4 d-none d-md-flex align-items-center gap-3 border border-light">
                        <div class="bg-success-soft text-success rounded-circle p-2">
                            <i class="bi bi-shield-lock-fill fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-black text-dark mb-0">@Loc.T("Index_Secure")</div>
                            <small class="text-muted">@Loc.T("Index_Compliant")</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Advantages Section -->
<section class="py-5" style="background: #fff;">
    <div class="container py-5">
        <h2 class="hp-section-title">
            @Loc.T("Index_Adv_Title")
        </h2>
        
        <div class="hp-feature-grid">
            <div class="hp-feature-card">
                <div class="hp-feature-icon">
                    <i class="bi bi-lightning-charge"></i>
                </div>
                <h4 class="fw-bold mb-3">@Loc.T("Index_Adv_1")</h4>
                <p class="text-muted mb-0">@Loc.T("Index_Adv_1_Desc")</p>
            </div>

            <div class="hp-feature-card">
                <div class="hp-feature-icon">
                    <i class="bi bi-shield-check"></i>
                </div>
                <h4 class="fw-bold mb-3">@Loc.T("Index_Adv_2")</h4>
                <p class="text-muted mb-0">@Loc.T("Index_Adv_2_Desc")</p>
            </div>

            <div class="hp-feature-card">
                <div class="hp-feature-icon">
                    <i class="bi bi-people"></i>
                </div>
                <h4 class="fw-bold mb-3">@Loc.T("Index_Adv_3")</h4>
                <p class="text-muted mb-0">@Loc.T("Index_Adv_3_Desc")</p>
            </div>

            <div class="hp-feature-card">
                <div class="hp-feature-icon">
                    <i class="bi bi-cloud-arrow-up"></i>
                </div>
                <h4 class="fw-bold mb-3">@Loc.T("Index_Adv_4")</h4>
                <p class="text-muted mb-0">@Loc.T("Index_Adv_4_Desc")</p>
            </div>

            <div class="hp-feature-card">
                <div class="hp-feature-icon">
                    <i class="bi bi-graph-up-arrow"></i>
                </div>
                <h4 class="fw-bold mb-3">@Loc.T("Index_Adv_5")</h4>
                <p class="text-muted mb-0">@Loc.T("Index_Adv_5_Desc")</p>
            </div>

            <div class="hp-feature-card bg-primary text-white border-0">
                <div class="hp-feature-icon bg-white bg-opacity-20 text-white">
                    <i class="bi bi-plus-circle"></i>
                </div>
                <h4 class="fw-bold mb-3">@Loc.T("Index_Adv_6_Title")</h4>
                <p class="text-white text-opacity-75 mb-4">@Loc.T("Index_Adv_6_Desc")</p>
                <a asp-action="Register" class="btn btn-light rounded-pill px-4 fw-bold">@Loc.T("Index_Adv_6_Btn")</a>
            </div>
        </div>
    </div>
</section>

<!-- Stats Section -->
<section class="py-5 bg-light">
    <div class="container py-5">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="hp-stat-glass">
                    <div class="hp-stat-value">@(ViewBag.TotalRecords ?? 0)+</div>
                    <div class="hp-stat-label">@Loc.T("Index_Stats_Records")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="hp-stat-glass">
                    <div class="hp-stat-value">@(ViewBag.TotalDoctors ?? 0)+</div>
                    <div class="hp-stat-label">@Loc.T("Index_Stats_Doctors")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="hp-stat-glass">
                    <div class="hp-stat-value">@(ViewBag.TotalUsers ?? 0)+</div>
                    <div class="hp-stat-label">@Loc.T("Index_Stats_Users")</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Trust Section -->
<section class="py-5">
    <div class="container text-center">
        <p class="text-muted small text-uppercase fw-bold letter-spacing-1 mb-5">@Loc.T("Index_TrustedBy")</p>
        <div class="row align-items-center hp-trust-logos g-5 justify-content-center">
            <div class="col-12 col-sm-6 col-md-3 d-flex align-items-center justify-content-center gap-3">
                <img src="/images/hospitals/vma_logo.png" style="max-height: 44px; width: auto; object-fit: contain;" alt="@Loc.T("Hosp_VMA")" class="img-fluid">
                <span class="fw-bold text-dark fs-5">@Loc.T("Hosp_VMA")</span>
            </div>
            <div class="col-12 col-sm-6 col-md-3 d-flex align-items-center justify-content-center gap-3">
                <img src="/images/hospitals/pirogov_logo.png" style="max-height: 44px; width: auto; object-fit: contain;" alt="@Loc.T("Hosp_Pirogov")" class="img-fluid">
                <span class="fw-bold text-dark fs-5">@Loc.T("Hosp_Pirogov")</span>
            </div>
            <div class="col-12 col-sm-6 col-md-3 d-flex align-items-center justify-content-center gap-3">
                <img src="/images/hospitals/alexandrovska_logo.png" style="max-height: 44px; width: auto; object-fit: contain;" alt="@Loc.T("Hosp_Alexandrovska")" class="img-fluid">
                <span class="fw-bold text-dark fs-5">@Loc.T("Hosp_Alexandrovska")</span>
            </div>
            <div class="col-12 col-sm-6 col-md-3 d-flex align-items-center justify-content-center gap-3">
                <img src="/images/hospitals/tokuda_logo.png" style="max-height: 44px; width: auto; object-fit: contain;" alt="@Loc.T("Hosp_Tokuda")" class="img-fluid">
                <span class="fw-bold text-dark fs-5">@Loc.T("Hosp_Tokuda")</span>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
}
