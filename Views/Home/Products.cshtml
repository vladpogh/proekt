                    <p style="color: #6b7280; font-size: 0.95rem; margin-bottom: 0.75rem;">@Loc.T("Products_Dimensions") @Loc.T("Products_FormatA5")</p>
                    <p style="color: #4b5563; line-height: 1.6; margin-bottom: 1rem; font-size: 0.95rem;">@Loc.T("Products_Prod2_Desc")</p>
                    <div style="margin-bottom: 1.5rem;">
                        <p style="color: #000; font-weight: 700; font-size: 0.95rem; margin-bottom: 0.5rem;">@Loc.T("Products_Spec")</p>
