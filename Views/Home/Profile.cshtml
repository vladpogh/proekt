@inject proekt.Services.TranslationService Loc
@{
    ViewData["Title"] = "My Profile";
    var user = ViewBag.User as proekt.Models.User;
    var application = ViewBag.Application as proekt.Models.DoctorApplication;
    var inquiries = ViewBag.AllInquiries as List<proekt.Models.ContactInquiry>;
    var userRole = Context.Session.GetString("UserRole");
}

<div class="profile-container">
    <!-- Sidebar -->
    <div class="profile-sidebar">
        <div class="sidebar-header">
            <div class="avatar-circle">
                @(user?.FullName?.Substring(0, 1).ToUpper() ?? "U")
            </div>
            <h5 class="mt-2 mb-0 text-white">@user?.FullName</h5>
            <small class="text-white-50">@user?.Email</small>
            <span class="badg-role mt-2">@user?.Role</span>
        </div>
        
        <div class="sidebar-menu">
            <a href="#" class="menu-item active" id="link-personal-info" onclick="showSection('personal-info')">
                <i class="bi bi-person"></i> @Loc.T("PersonalInfo") <i class="bi bi-chevron-right ms-auto"></i>
            </a>
            <a href="#" class="menu-item" id="link-change-password" onclick="showSection('change-password')">
                <i class="bi bi-lock"></i> @Loc.T("ChangePassword")
            </a>

            <a href="@Url.Action("Contact", "Home")" class="menu-item">
                <i class="bi bi-envelope"></i> @Loc.T("Contact")
            </a>
            <a href="#" class="menu-item" id="link-inquiries" onclick="showSection('inquiries')">
                <i class="bi bi-chat-left-text"></i> @Loc.T("MyInquiries")
                 @if(inquiries != null && inquiries.Count > 0) {
                    <span class="badge bg-primary ms-auto">@inquiries.Count</span>
                 }
            </a>
            <a href="@Url.Action("Logout", "Home")" class="menu-item text-danger mt-auto">
                <i class="bi bi-box-arrow-right"></i> @Loc.T("SignOut")
            </a>
        </div>
    </div>

    <!-- Main Content -->
    <div class="profile-content">
        @if (TempData["ProfileMessage"] != null)
        {
            <div class="alert alert-info mb-4">@TempData["ProfileMessage"]</div>
        }

        <div id="personal-info-section">
            <div class="content-card">
                <div class="card-header-clean">
                    <div>
                        <h4 class="mb-1">@Loc.T("PersonalInfo")</h4>
                        <p class="text-muted mb-0">@Loc.T("ManageDetails")</p>
                    </div>
                    <div>
                        <!-- Toggle Edit Mode Button -->
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="btnEditProfile" onclick="toggleEditMode()">
                            <i class="bi bi-pencil"></i> @Loc.T("EditProfile")
                        </button>
                        <button type="button" class="btn btn-outline-secondary btn-sm d-none" id="btnCancelEdit" onclick="cancelEditMode()">
                            <i class="bi bi-x"></i> @Loc.T("Cancel")
                        </button>
                    </div>
                </div>

                <form asp-action="UpdateProfile" method="post" id="profileForm">
                    <div class="row g-4 mt-2">
                        <div class="col-md-6">
                            <div class="form-group-custom">
                                <label><i class="bi bi-person"></i> @Loc.T("FullName")</label>
                                <input type="text" class="form-control-custom" name="fullName" value="@user?.FullName" readonly>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group-custom">
                                <label><i class="bi bi-envelope"></i> @Loc.T("EmailAddress")</label>
                                <div class="form-control-static">@user?.Email</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group-custom">
                                <label><i class="bi bi-shield"></i> @Loc.T("Role")</label>
                                <div class="form-control-static fw-bold">@user?.Role</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group-custom">
                                <label><i class="bi bi-telephone"></i> @Loc.T("PhoneNumber")</label>
                                <input type="text" class="form-control-custom" name="phone" value="@user?.PhoneNumber" placeholder="+359 ..." readonly>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group-custom">
                                <label><i class="bi bi-geo-alt"></i> @Loc.T("Location")</label>
                                <input type="text" class="form-control-custom" name="location" value="@user?.Location" placeholder="City, Country" readonly>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group-custom">
                                <label><i class="bi bi-calendar"></i> @Loc.T("MemberSince")</label>
                                <div class="form-control-static">@user?.CreatedAt.ToString("MMMM yyyy")</div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="d-none mt-4 text-end" id="saveActions">
                        <button type="submit" class="btn btn-primary">@Loc.T("SaveChanges")</button>
                    </div>
                </form>
            </div>
        </div>

        <div id="change-password-section" class="d-none">
            <div class="content-card">
                <div class="card-header-clean">
                    <div>
                        <h4 class="mb-1">@Loc.T("ChangePassword")</h4>
                        <p class="text-muted mb-0">@Loc.T("EnsureSecurity")</p>
                    </div>
                </div>

                <form asp-action="ChangePassword" method="post" id="passwordForm" onsubmit="return validatePassword()">
                    <input type="hidden" name="userId" value="@user?.Id" />
                    
                    <div class="row g-4 mt-2">
                        <div class="col-md-12">
                             <div class="form-group-custom">
                                <label><i class="bi bi-key"></i> @Loc.T("CurrentPassword")</label>
                                 <input type="password" class="form-control-custom" name="currentPassword" id="currentPassword" required>
                             </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group-custom">
                                <label><i class="bi bi-lock"></i> @Loc.T("NewPassword")</label>
                                <input type="password" class="form-control-custom" name="newPassword" id="newPassword" required>
                                
                                <!-- Password Requirements UI -->
                                <div id="passwordRequirements" style="margin-top: 0.75rem; font-size: 0.85rem; display: none;">
                                    <p style="font-weight: 600; margin-bottom: 0.5rem; color: #666;">@Loc.T("PassRequirements")</p>
                                    <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.25rem;">
                                        <li id="req-length" style="color: #999; display: flex; align-items: center; gap: 0.5rem;">
                                            <span class="icon">○</span> @Loc.T("PassLength")
                                        </li>
                                        <li id="req-special" style="color: #999; display: flex; align-items: center; gap: 0.5rem;">
                                            <span class="icon">○</span> @Loc.T("PassSpecial")
                                        </li>
                                        <li id="req-number" style="color: #999; display: flex; align-items: center; gap: 0.5rem;">
                                            <span class="icon">○</span> @Loc.T("PassNumber")
                                        </li>
                                        <li id="req-not1234" style="color: #999; display: flex; align-items: center; gap: 0.5rem;">
                                            <span class="icon">○</span> @Loc.T("PassNot1234")
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group-custom">
                                <label><i class="bi bi-lock-fill"></i> @Loc.T("ConfirmPassword")</label>
                                <input type="password" class="form-control-custom" id="confirmPassword" required>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mt-4 text-end">
                        <button type="submit" id="passwordSubmitBtn" disabled class="btn btn-primary" style="background: #999; border-color: #999; cursor: not-allowed;">@Loc.T("UpdatePassword")</button>
                    </div>
                </form>
            </div>
        </div>

        <div id="inquiries-section" class="d-none">
            <div class="content-card">
                <div class="card-header-clean">
                    <div>
                        <h4 class="mb-1">@Loc.T("MyInquiries")</h4>
                        <p class="text-muted mb-0">@Loc.T("TrackRequests")</p>
                    </div>
                </div>

                <!-- Doctor Application Status -->
                <div class="mt-4">
                    <h6 class="fw-bold mb-3"><i class="bi bi-clipboard2-pulse me-2"></i>@Loc.T("DoctorAppStatus")</h6>
                    @if (application != null)
                    {
                        <div class="alert @(application.Status == proekt.Models.ApplicationStatus.Approved ? "alert-success" : (application.Status == proekt.Models.ApplicationStatus.Rejected ? "alert-danger" : "alert-warning"))">
                            <div class="d-flex justify-content-between align-items-center">
                                <strong>@Loc.T("Status"): @application.Status</strong>
                                <small>@Loc.T("SubmittedOn") @application.CreatedAt.ToString("dd MMM yyyy")</small>
                            </div>
                            @if (!string.IsNullOrEmpty(application.AdminComment))
                            {
                                <div class="mt-2 border-top pt-2">
                                    <strong>@Loc.T("AdminFeedback"):</strong>
                                    <p class="mb-0">@application.AdminComment</p>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">@Loc.T("NoDoctorApp")</p>
                        <a asp-action="DoctorApplication" class="btn btn-sm btn-outline-primary">@Loc.T("ApplyNow")</a>
                    }
                </div>

                <hr class="my-4">

                <!-- Contact Inquiries -->
                <div>
                    <h6 class="fw-bold mb-3"><i class="bi bi-chat-dots me-2"></i>@Loc.T("ContactHistory")</h6>
                    @if (inquiries != null && inquiries.Any())
                    {
                        <div class="inquiry-list">
                            @foreach (var inq in inquiries)
                            {
                                <div class="inquiry-item mb-3 p-3 border rounded">
                                    <div class="d-flex justify-content-between">
                                        <h6 class="fw-bold text-primary mb-1">@inq.Subject</h6>
                                        <small class="text-muted">@inq.CreatedAt.ToString("g")</small>
                                    </div>
                                    <p class="mb-2">@inq.Message</p>
                                    @if (!string.IsNullOrEmpty(inq.AdminResponse))
                                    {
                                        <div class="bg-light p-3 rounded mt-2 border-start border-4 border-primary">
                                            <div class="d-flex align-items-center mb-1">
                                                <i class="bi bi-reply-fill text-primary me-2"></i>
                                                <strong class="small">@Loc.T("AdminFeedback"):</strong>
                                            </div>
                                            <p class="mb-0 italic small">@inq.AdminResponse</p>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-muted small mt-2">
                                            <i class="bi bi-clock me-1"></i> @Loc.T("AwaitingResponse")
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">@Loc.T("NoInquiries")</p>
                        <a asp-action="Contact" class="btn btn-sm btn-outline-secondary">@Loc.T("SendInquiry")</a>
                    }
                </div>
            </div>
        </div>

        <div class="content-card mt-4 bg-light-blue">
            <div class="d-flex align-items-start">
                <div class="icon-box me-3">
                    <i class="bi bi-shield-check text-primary"></i>
                </div>
                <div>
                    <h6 class="fw-bold mb-1">@Loc.T("AccountSecurity")</h6>
                    <p class="text-muted small mb-0">@Loc.T("SecurityDesc")</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleEditMode() {
            var inputs = document.querySelectorAll('#profileForm input[name]');
            inputs.forEach(input => {
                input.readOnly = false;
                input.classList.add('editable');
            });
            
            document.getElementById('btnEditProfile').classList.add('d-none');
            document.getElementById('btnCancelEdit').classList.remove('d-none');
            document.getElementById('saveActions').classList.remove('d-none');
        }

        function cancelEditMode() {
             var inputs = document.querySelectorAll('#profileForm input[name]');
            inputs.forEach(input => {
                input.readOnly = true;
                input.classList.remove('editable');
            });
             document.getElementById('btnEditProfile').classList.remove('d-none');
            document.getElementById('btnCancelEdit').classList.add('d-none');
            document.getElementById('saveActions').classList.add('d-none');
            
            // Optional: reload to reset values
            location.reload();
        }

        function showSection(sectionName) {
            // Hide all sections
            document.getElementById('personal-info-section').classList.add('d-none');
            document.getElementById('change-password-section').classList.add('d-none');
            document.getElementById('inquiries-section').classList.add('d-none');
            
            // Remove active class from sidebar links
            document.getElementById('link-personal-info').classList.remove('active');
            document.getElementById('link-change-password').classList.remove('active');
            document.getElementById('link-inquiries').classList.remove('active');
            
            // Remove chevron from all links
            document.querySelectorAll('.menu-item .bi-chevron-right').forEach(el => el.remove());

            // Show selected section
            document.getElementById(sectionName + '-section').classList.remove('d-none');
            
            // Add active class and chevron
            var activeLink = document.getElementById('link-' + sectionName);
            activeLink.classList.add('active');
            if (!activeLink.querySelector('.bi-chevron-right')) {
                activeLink.innerHTML += ' <i class="bi bi-chevron-right ms-auto"></i>';
            }
        }

        function validatePassword() {
            var newPass = document.getElementById('newPassword').value;
            var confirmPass = document.getElementById('confirmPassword').value;
            if (newPass !== confirmPass) {
                alert("Passwords do not match!");
                return false;
            }
            return true;
        }

        document.addEventListener('DOMContentLoaded', function() {
            const passwordInput = document.getElementById('newPassword');
            const requirementsDiv = document.getElementById('passwordRequirements');
            const reqLength = document.getElementById('req-length');
            const reqSpecial = document.getElementById('req-special');
            const reqNumber = document.getElementById('req-number');
            const reqNot1234 = document.getElementById('req-not1234');

            if (passwordInput) {
                const submitBtn = document.getElementById('passwordSubmitBtn');
                
                passwordInput.addEventListener('focus', () => {
                    requirementsDiv.style.display = 'block';
                });

                passwordInput.addEventListener('input', function() {
                    const val = this.value;
                    
                    const isLengthValid = val.length >= 8;
                    const isSpecialValid = /[^A-Za-z0-9]/.test(val);
                    const isNumberValid = /[0-9]/.test(val);
                    const isNot1234Valid = val !== '1234' && val.length > 0;

                    // Validate requirements
                    updateRequirement(reqLength, isLengthValid);
                    updateRequirement(reqSpecial, isSpecialValid);
                    updateRequirement(reqNumber, isNumberValid);
                    updateRequirement(reqNot1234, isNot1234Valid);

                    // Enable/Disable Button
                    if (isLengthValid && isSpecialValid && isNumberValid && isNot1234Valid) {
                        submitBtn.disabled = false;
                        submitBtn.style.background = ''; // reset to default primary
                        submitBtn.style.borderColor = '';
                        submitBtn.style.cursor = 'pointer';
                    } else {
                        submitBtn.disabled = true;
                        submitBtn.style.background = '#999';
                        submitBtn.style.borderColor = '#999';
                        submitBtn.style.cursor = 'not-allowed';
                    }
                });
            }

            function updateRequirement(el, isValid) {
                if (!el) return;
                const icon = el.querySelector('.icon');
                if (isValid) {
                    el.style.color = '#059669'; // success green
                    icon.textContent = '●';
                } else {
                    el.style.color = '#999';
                    icon.textContent = '○';
                }
            }
        });

        // Check for section query param or hash on load
        window.onload = function() {
            var urlParams = new URLSearchParams(window.location.search);
            if (urlParams.get('tab') === 'password') {
                showSection('change-password');
            }
        };
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
}
