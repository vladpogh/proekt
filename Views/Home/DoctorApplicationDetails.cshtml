@inject proekt.Services.TranslationService Loc
@model proekt.Models.DoctorApplication

@{
    ViewData["Title"] = Loc.T("Application") + " #" + Model.Id;
}

<div class="admin-details-container py-5">
    <div class="container">
        <!-- Breadcrumb / Back -->
        <div class="mb-4">
            <a asp-action="AdminPanel" class="btn btn-link text-decoration-none p-0 d-inline-flex align-items-center gap-2 text-muted hover-primary">
                <i class="bi bi-arrow-left"></i>
                <span>@Loc.T("Cancel")</span>
            </a>
        </div>

        <div class="row g-4">
            <!-- Left Column: Details -->
            <div class="col-lg-8">
                <div class="content-card premium-card">
                    <div class="card-header-clean border-bottom pb-3 mb-4 d-flex justify-content-between align-items-center">
                        <div>
                            <h2 class="h4 mb-1 fw-bold">@Loc.T("ReviewApplication") #@Model.Id</h2>
                            <p class="text-muted small mb-0">@Loc.T("Submitted"): @Model.CreatedAt.ToString("g")</p>
                        </div>
                        <span class="badge bg-warning-soft text-warning px-3 py-2 rounded-pill fw-bold">@Loc.T("PendingCount")</span>
                    </div>

                    <div class="app-metadata mb-4">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="item-info">
                                    <label class="text-muted small text-uppercase fw-bold">@Loc.T("UserId")</label>
                                    <p class="mb-0 fw-bold">@Model.UserId</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="app-about mb-4">
                        <label class="text-muted small text-uppercase fw-bold mb-2 d-block">@Loc.T("About")</label>
                        <div class="p-4 bg-light rounded-4 italic-message">
                            @Model.About
                        </div>
                    </div>

                    <div class="app-documents">
                        <label class="text-muted small text-uppercase fw-bold mb-3 d-block">@Loc.T("SupportingDocuments")</label>
                        <div class="row g-3">
                            <!-- Emp Contract -->
                            <div class="col-md-4">
                                <div class="doc-card h-100 d-flex flex-column">
                                    <div class="doc-icon"><i class="bi bi-file-earmark-text"></i></div>
                                    <h6 class="fw-bold mb-2">@Loc.T("EmploymentContract")</h6>
                                    @if (!string.IsNullOrEmpty(Model.EmploymentContractPath)) {
                                        <a href="@Model.EmploymentContractPath" target="_blank" class="btn btn-light btn-sm mt-auto w-100">@Loc.T("ViewFile")</a>
                                    } else {
                                        <span class="text-muted small mt-auto">@Loc.T("NotProvided")</span>
                                    }
                                </div>
                            </div>
                            <!-- ID Card -->
                            <div class="col-md-4">
                                <div class="doc-card h-100 d-flex flex-column">
                                    <div class="doc-icon"><i class="bi bi-person-badge"></i></div>
                                    <h6 class="fw-bold mb-2">@Loc.T("IDCard")</h6>
                                    @if (!string.IsNullOrEmpty(Model.IdCardPath)) {
                                        <a href="@Model.IdCardPath" target="_blank" class="btn btn-light btn-sm mt-auto w-100">@Loc.T("ViewFile")</a>
                                    } else {
                                        <span class="text-muted small mt-auto">@Loc.T("NotProvided")</span>
                                    }
                                </div>
                            </div>
                            <!-- Medical License -->
                            <div class="col-md-4">
                                <div class="doc-card h-100 d-flex flex-column">
                                    <div class="doc-icon"><i class="bi bi-patch-check"></i></div>
                                    <h6 class="fw-bold mb-2">@Loc.T("MedicalLicense")</h6>
                                    @if (!string.IsNullOrEmpty(Model.MedicalLicensePath)) {
                                        <a href="@Model.MedicalLicensePath" target="_blank" class="btn btn-light btn-sm mt-auto w-100">@Loc.T("ViewFile")</a>
                                    } else {
                                        <span class="text-muted small mt-auto">@Loc.T("NotProvided")</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Actions -->
            <div class="col-lg-4">
                <div class="content-card sticky-top" style="top: 2rem; z-index: 10;">
                    <h5 class="fw-bold mb-4">@Loc.T("Decision")</h5>
                    
                    <form asp-action="ApproveDoctorApplication" method="post" id="approveForm">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label small fw-bold">@Loc.T("CommentOptional")</label>
                            <textarea name="adminComment" class="form-control" rows="3" placeholder="@Loc.T("CommentOptional")..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-success w-100 py-3 fw-bold rounded-4 mb-3 d-flex align-items-center justify-content-center gap-2">
                            <i class="bi bi-check-circle-fill"></i> @Loc.T("Approve")
                        </button>
                    </form>

                    <form asp-action="RejectDoctorApplication" method="post" id="rejectForm">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-outline-danger w-100 py-2 fw-bold rounded-4 d-flex align-items-center justify-content-center gap-2">
                            <i class="bi bi-x-circle"></i> @Loc.T("Reject")
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@* Inline Partial replacement to avoid creating extra files if not strictly needed, 
   but for a premium look, let's just implement the logic directly if needed or use a small CSS class *@

<style>
    .admin-details-container { background: #f8faff; min-height: 100vh; }
    .premium-card { border-top: 5px solid #0052CC; }
    .bg-warning-soft { background: rgba(255, 193, 7, 0.1); }
    .hover-primary:hover { color: #0052CC !important; }
    
    .content-card {
        background: #fff;
        border-radius: 20px;
        padding: 2.5rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.04);
        border: 1px solid #edf2f7;
    }
    
    .italic-message { color: #4a5568; line-height: 1.6; border-left: 4px solid #e2e8f0; }
    
    .doc-card {
        background: #fcfdfe;
        border: 1px solid #edf2f7;
        border-radius: 16px;
        padding: 1.25rem;
        transition: all 0.2s;
    }
    .doc-card:hover { border-color: #0052CC; background: #fff; transform: translateY(-3px); box-shadow: 0 8px 15px rgba(0,0,0,0.05); }
    
    .doc-icon {
        width: 48px;
        height: 48px;
        background: #eef2ff;
        color: #0052CC;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 1rem;
    }
</style>

@* Inline replacement for the card to keep it clean *@
@functions {
    public async Task<string> DocCardHtml(string title, string path, string icon) {
        bool hasFile = !string.IsNullOrEmpty(path);
        return $@"
        <div class='col-md-4'>
            <div class='doc-card h-100 d-flex flex-direction-column'>
                <div class='doc-icon'><i class='bi {icon}'></i></div>
                <h6 class='fw-bold mb-2'>{title}</h6>
                {(hasFile ? $"<a href='{path}' target='_blank' class='btn btn-light btn-sm mt-auto w-100'>{Loc.T("ViewFile")}</a>" : $"<span class='text-muted small mt-auto'>{Loc.T("NotProvided")}</span>")}
            </div>
        </div>";
    }
}

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
}

<div style="display:none">
    @* We can't actually use the functions like that in Razor easily without complex setup, 
       so I will just unroll the DocCard logic into the main view for simplicity/speed *@
</div>

@* Unrolling the DocCard logic for reliability *@
