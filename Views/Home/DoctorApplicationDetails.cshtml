@inject proekt.Services.TranslationService Loc
@model proekt.Models.DoctorApplication

@{
    ViewData["Title"] = Loc.T("Application") + " #" + Model.Id;
}

<div class="admin-details-container py-5">
    <div class="container">

        <!-- Back -->
        <div class="mb-4">
            <a asp-action="AdminPanel" class="btn btn-link text-decoration-none p-0 d-inline-flex align-items-center gap-2 text-muted hover-primary">
                <i class="bi bi-arrow-left"></i>
                <span>@Loc.T("Cancel")</span>
            </a>
        </div>

        <div class="row g-4">

            <!-- LEFT -->
            <div class="col-lg-8">
                <div class="content-card premium-card">

                    <div class="border-bottom pb-3 mb-4 d-flex justify-content-between align-items-center">
                        <div>
                            <h2 class="h4 mb-1 fw-bold">
                                @Loc.T("ReviewApplication") #@Model.Id
                            </h2>
                            <p class="text-muted small mb-0">
                                @Loc.T("Submitted"): @Model.CreatedAt.ToString("g")
                            </p>
                        </div>

                        <span class="badge bg-warning-soft text-warning px-3 py-2 rounded-pill fw-bold">
                            @Loc.T("PendingCount")
                        </span>
                    </div>

                    <div class="mb-4">
                        <label class="text-muted small text-uppercase fw-bold">
                            @Loc.T("UserId")
                        </label>
                        <p class="fw-bold mb-0">@Model.UserId</p>
                    </div>

                    <div class="mb-4">
                        <label class="text-muted small text-uppercase fw-bold mb-2 d-block">
                            @Loc.T("About")
                        </label>

                        <div class="p-4 bg-light rounded-4 italic-message">
                            @Model.About
                        </div>
                    </div>

                    <!-- DOCUMENTS -->
                    <div>
                        <label class="text-muted small text-uppercase fw-bold mb-3 d-block">
                            @Loc.T("SupportingDocuments")
                        </label>

                        <div class="row g-3">

                            <!-- EMP CONTRACT -->
                            <div class="col-md-4">
                                <div class="doc-card">
                                    <div class="doc-icon"><i class="bi bi-file-earmark-text"></i></div>
                                    <h6 class="fw-bold mb-2">@Loc.T("EmploymentContract")</h6>

                                    @if (!string.IsNullOrEmpty(Model.EmploymentContractPath))
                                    {
                                        <a asp-action="DownloadDocument" asp-route-id="@Model.Id" asp-route-type="contract" target="_blank"
                                           class="btn btn-light btn-sm mt-auto w-100">
                                            @Loc.T("ViewFile")
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small mt-auto">@Loc.T("NotProvided")</span>
                                    }
                                </div>
                            </div>

                            <!-- ID -->
                            <div class="col-md-4">
                                <div class="doc-card">
                                    <div class="doc-icon"><i class="bi bi-person-badge"></i></div>
                                    <h6 class="fw-bold mb-2">@Loc.T("IDCard")</h6>

                                    @if (!string.IsNullOrEmpty(Model.IdCardPath))
                                    {
                                        <a asp-action="DownloadDocument" asp-route-id="@Model.Id" asp-route-type="idcard" target="_blank"
                                           class="btn btn-light btn-sm mt-auto w-100">
                                            @Loc.T("ViewFile")
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small mt-auto">@Loc.T("NotProvided")</span>
                                    }
                                </div>
                            </div>

                            <!-- LICENSE -->
                            <div class="col-md-4">
                                <div class="doc-card">
                                    <div class="doc-icon"><i class="bi bi-patch-check"></i></div>
                                    <h6 class="fw-bold mb-2">@Loc.T("MedicalLicense")</h6>

                                    @if (!string.IsNullOrEmpty(Model.MedicalLicensePath))
                                    {
                                        <a asp-action="DownloadDocument" asp-route-id="@Model.Id" asp-route-type="license" target="_blank"
                                           class="btn btn-light btn-sm mt-auto w-100">
                                            @Loc.T("ViewFile")
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small mt-auto">@Loc.T("NotProvided")</span>
                                    }
                                </div>
                            </div>

                        </div>
                    </div>

                </div>
            </div>

            <!-- RIGHT -->
            <div class="col-lg-4">
                <div class="content-card sticky-top" style="top:2rem;">

                    <h5 class="fw-bold mb-4">@Loc.T("Decision")</h5>

                    <form asp-action="ApproveDoctorApplication" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />

                        <textarea name="adminComment" class="form-control mb-3" rows="3"
                                  placeholder="@Loc.T("CommentOptional")"></textarea>

                        <button type="submit" class="btn btn-success w-100 mb-3">
                            @Loc.T("Approve")
                        </button>
                    </form>

                    <form asp-action="RejectDoctorApplication" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />

                        <button type="submit" class="btn btn-outline-danger w-100">
                            @Loc.T("Reject")
                        </button>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

<style>
    .admin-details-container { background:#f8faff; min-height:100vh; }
    .premium-card { border-top:5px solid #0052CC; }

    .content-card {
        background:#fff;
        border-radius:20px;
        padding:2.5rem;
        box-shadow:0 10px 30px rgba(0,0,0,0.04);
        border:1px solid #edf2f7;
    }

    .doc-card {
        background:#fcfdfe;
        border:1px solid #edf2f7;
        border-radius:16px;
        padding:1.25rem;
        display:flex;
        flex-direction:column;
    }

    .doc-icon {
        width:48px;
        height:48px;
        background:#eef2ff;
        color:#0052CC;
        border-radius:12px;
        display:flex;
        align-items:center;
        justify-content:center;
        margin-bottom:1rem;
    }

    .italic-message {
        border-left:4px solid #e2e8f0;
        color:#4a5568;
    }
</style>

@section Scripts {
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
}