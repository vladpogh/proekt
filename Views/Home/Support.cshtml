@inject proekt.Services.TranslationService Loc
@{
    ViewData["Title"] = Loc.T("Support_Title") + " - MedReports";
}

<div class="container" style="padding: 60px 0;">
    <h1 style="font-size: 3rem; font-weight: 900;">@Loc.T("Support_Title")</h1>
    <p style="color:#666; margin-bottom:40px;">@Loc.T("Support_Sub")</p>

    <h2 style="font-size:1.6rem; font-weight:700; margin-bottom:1rem;">@Loc.T("Support_Doc_Title")</h2>
    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div style="background:white; padding:24px; border-radius:12px; border:1px solid #eef2f6;">
                <div style="display:flex; gap:16px; align-items:center;">
                    <div style="width:48px; height:48px; background:linear-gradient(135deg,#e8f0ff,#dbeafe); border-radius:8px; display:flex; align-items:center; justify-content:center;">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3 6h18v12H3z" fill="#fff" opacity="0.9"/></svg>
                    </div>
                    <div>
                        <h3 style="margin:0; font-size:1.1rem; font-weight:700;">@Loc.T("Support_Doc1_Title")</h3>
                        <p style="margin:4px 0 0; color:#777;">@Loc.T("Support_Doc1_Sub")</p>
                    </div>
                </div>
                <div style="margin-top:18px;">
                    <a class="btn btn-outline-secondary" href="#" role="button">⬇️ @Loc.T("Support_Btn_Download")</a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div style="background:white; padding:24px; border-radius:12px; border:1px solid #eef2f6;">
                <div style="display:flex; gap:16px; align-items:center;">
                    <div style="width:48px; height:48px; background:linear-gradient(135deg,#e8f0ff,#dbeafe); border-radius:8px; display:flex; align-items:center; justify-content:center;">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M4 6h16v12H4z" fill="#fff" opacity="0.9"/></svg>
                    </div>
                    <div>
                        <h3 style="margin:0; font-size:1.1rem; font-weight:700;">@Loc.T("Support_Doc2_Title")</h3>
                        <p style="margin:4px 0 0; color:#777;">@Loc.T("Support_Doc2_Sub")</p>
                    </div>
                </div>
                <div style="margin-top:18px;">
                    <a class="btn btn-outline-secondary" href="#" role="button">⬇️ @Loc.T("Support_Btn_Download")</a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div style="background:white; padding:24px; border-radius:12px; border:1px solid #eef2f6;">
                <div style="display:flex; gap:16px; align-items:center;">
                    <div style="width:48px; height:48px; background:linear-gradient(135deg,#e8f0ff,#dbeafe); border-radius:8px; display:flex; align-items:center; justify-content:center;">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 6h12v12H6z" fill="#fff" opacity="0.9"/></svg>
                    </div>
                    <div>
                        <h3 style="margin:0; font-size:1.1rem; font-weight:700;">@Loc.T("Support_Doc3_Title")</h3>
                        <p style="margin:4px 0 0; color:#777;">@Loc.T("Support_Doc3_Sub")</p>
                    </div>
                </div>
                <div style="margin-top:18px;">
                    <a class="btn btn-outline-secondary" href="#" role="button">⬇️ @Loc.T("Support_Btn_Download")</a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div style="background:white; padding:24px; border-radius:12px; border:1px solid #eef2f6;">
                <div style="display:flex; gap:16px; align-items:center;">
                    <div style="width:48px; height:48px; background:linear-gradient(135deg,#e8f0ff,#dbeafe); border-radius:8px; display:flex; align-items:center; justify-content:center;">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 6h12v12H6z" fill="#fff" opacity="0.9"/></svg>
                    </div>
                    <div>
                        <h3 style="margin:0; font-size:1.1rem; font-weight:700;">@Loc.T("Support_Doc4_Title")</h3>
                        <p style="margin:4px 0 0; color:#777;">@Loc.T("Support_Doc4_Sub")</p>
                    </div>
                </div>
                <div style="margin-top:18px;">
                    <a class="btn btn-outline-secondary" href="#" role="button">⬇️ @Loc.T("Support_Btn_Download")</a>
                </div>
            </div>
        </div>
    </div>

    <h2 style="font-size:1.6rem; font-weight:700; margin-bottom:1rem;">@Loc.T("Support_FAQ_Title")</h2>

    <div class="accordion" id="faqAccordion">
        <div class="accordion-item">
            <h2 class="accordion-header" id="faqHeading1">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq1" aria-expanded="false" aria-controls="faq1">
                    @Loc.T("Support_FAQ1_Q")
                </button>
            </h2>
            <div id="faq1" class="accordion-collapse collapse" aria-labelledby="faqHeading1" data-bs-parent="#faqAccordion">
                <div class="accordion-body">@Loc.T("Support_FAQ1_A")</div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header" id="faqHeading2">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2" aria-expanded="false" aria-controls="faq2">
                    @Loc.T("Support_FAQ2_Q")
                </button>
            </h2>
            <div id="faq2" class="accordion-collapse collapse" aria-labelledby="faqHeading2" data-bs-parent="#faqAccordion">
                <div class="accordion-body">@Loc.T("Support_FAQ2_A")</div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header" id="faqHeading3">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3" aria-expanded="false" aria-controls="faq3">
                    @Loc.T("Support_FAQ3_Q")
                </button>
            </h2>
            <div id="faq3" class="accordion-collapse collapse" aria-labelledby="faqHeading3" data-bs-parent="#faqAccordion">
                <div class="accordion-body">@Loc.T("Support_FAQ3_A")</div>
            </div>
        </div>
    </div>

    <div style="margin-top:48px; background: linear-gradient(135deg,#3b82f6,#bfdbfe); padding:48px; border-radius:12px; color:white; text-align:center;">
        <div style="font-size:3rem; font-weight:900;">@Loc.T("Support_Help_Title")</div>
        <p style="margin-top:8px; color:rgba(255,255,255,0.9);">@Loc.T("Support_Help_Sub")</p>
        <a class="btn btn-light" asp-area="" asp-controller="Home" asp-action="Contact" style="margin-top:18px;">@Loc.T("Contact")</a>
    </div>
</div>
