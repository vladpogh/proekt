@inject proekt.Services.TranslationService Loc
@{
    ViewData["Title"] = Loc.T("AdminPanel");
}

<h2>@Loc.T("AdminPanel")</h2>

@inject proekt.Services.UserService UserService
@inject proekt.Services.DoctorApplicationService AppService
@using proekt.Models

@await Html.PartialAsync("~/Views/ClientMessages/_ClientMessagesNav.cshtml")


    <div class="mb-4">
        <h4>@Loc.T("DoctorApplications")</h4>
        <div id="applications-list">
            @foreach (var app in AppService.GetPending())
            {
                <div class="card mb-2 p-2">
                    <div><b>@Loc.T("DoctorApplications") #@app.Id</b> (@Loc.T("FullName"): @(UserService.GetUserById(app.UserId)?.FullName ?? "N/A"), @Loc.T("SubmittedOn"): @app.CreatedAt.ToString("g"))</div>
                        <a asp-action="DoctorApplicationDetails" asp-route-id="@app.Id" class="btn btn-outline-primary btn-sm mt-2">@Loc.T("ShowMore")</a>
                </div>
            }
            @if (!AppService.GetPending().Any())
            {
                <div class="text-muted">@Loc.T("NoPending")</div>
            }
        </div>
    </div>

<div class="mb-4">
    <h4>@Loc.T("CloseUserProfiles")</h4>
    <div id="users-list">
        @foreach (var user in UserService.GetAllUsers().Where(u => u.Role != UserRole.Admin && u.Role != UserRole.Manager))
        {
            <div class="card mb-2 p-2">
                <div><b>@user.FullName</b> (ID: @user.Id, @Loc.T("Role"): @Loc.T(user.Role.ToString()))</div>
                <form asp-action="TerminateUser" method="post" class="d-inline ms-2">
                    <input type="hidden" name="id" value="@user.Id" />
                    <button type="submit" class="btn btn-danger btn-sm">@Loc.T("Terminate")</button>
                </form>
            </div>
        }
        @if (!UserService.GetAllUsers().Any(u => u.Role != UserRole.Admin && u.Role != UserRole.Manager))
        {
            <div class="text-muted">@Loc.T("NoUsersToTerminate")</div>
        }
    </div>
</div>

@{
    var currentRole = Context.Session.GetString("UserRole");
}
@if (currentRole == "Manager")
{
    <div class="mb-4">
        <h4>@Loc.T("MakeRemoveAdmin")</h4>
        <div id="admin-management-list">
            @foreach (var user in UserService.GetAllUsers().Where(u => u.Role != UserRole.Manager))
            {
                <div class="card mb-2 p-2">
                    <div><b>@user.FullName</b> (ID: @user.Id, @Loc.T("Role"): @Loc.T(user.Role.ToString()))</div>
                    @if (user.Role == UserRole.Admin)
                    {
                        <form asp-action="RemoveAdmin" method="post" class="d-inline ms-2">
                            <input type="hidden" name="id" value="@user.Id" />
                            <button type="submit" class="btn btn-warning btn-sm">@Loc.T("RemoveAdmin")</button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="MakeAdmin" method="post" class="d-inline ms-2">
                            <input type="hidden" name="id" value="@user.Id" />
                            <button type="submit" class="btn btn-primary btn-sm">@Loc.T("MakeAdmin")</button>
                        </form>
                    }
                </div>
            }
            @if (!UserService.GetAllUsers().Any(u => u.Role != UserRole.Manager))
            {
                <div class="text-muted">@Loc.T("NoUsersToManage")</div>
            }
        </div>
    </div>
}
